---
interface Props {
  productName: string;
  galleryItems: Array<{
    type: 'image' | 'video';
    url: string;
    videoUrl?: string;
    thumbnail?: string;
  }>;
  isLoadingGallery: boolean;
}

const { productName, galleryItems, isLoadingGallery } = Astro.props;
---

<div class="relative">
  <div 
    class="bg-white border-2 border-gray-200 rounded-lg overflow-hidden relative"
    style="aspect-ratio: 16/9;"
  >
    {isLoadingGallery ? (
      <div class="absolute inset-0 bg-gray-100 animate-pulse" />
    ) : (
      <>
        {galleryItems.map((item, index) => (
          <div
            class={`absolute inset-0 transition-opacity duration-300 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
            data-index={index}
          >
            {item.type === 'video' ? (
              <div class="relative w-full h-full">
                <video
                  src={item.videoUrl}
                  poster={item.thumbnail}
                  controls
                  class="absolute inset-0 w-full h-full object-contain"
                >
                  <track kind="captions" />
                </video>
              </div>
            ) : (
              <img
                src={item.url}
                alt={`${productName} - ${index + 1}`}
                class="absolute inset-0 w-full h-full object-contain"
                loading={index === 0 ? 'eager' : 'lazy'}
              />
            )}
          </div>
        ))}
      </>
    )}

    {/* Navigation buttons */}
    <button
      class="absolute left-2 top-1/2 -translate-y-1/2 z-10 bg-white/80 hover:bg-white rounded-full p-2 shadow opacity-0 group-hover:opacity-100 transition-opacity"
      onclick="previousImage()"
      aria-label="Previous image"
    >
      <svg class="w-6 h-6 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <button
      class="absolute right-2 top-1/2 -translate-y-1/2 z-10 bg-white/80 hover:bg-white rounded-full p-2 shadow opacity-0 group-hover:opacity-100 transition-opacity"
      onclick="nextImage()"
      aria-label="Next image"
    >
      <svg class="w-6 h-6 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </button>
  </div>

  {/* Thumbnail gallery */}
  <div class="mt-4 flex gap-2 overflow-x-auto pb-2">
    {galleryItems.map((item, index) => (
      <button
        class={`relative w-24 h-24 flex-shrink-0 rounded-lg overflow-hidden border-2 cursor-pointer transition-colors ${
          index === 0 ? 'border-red-500' : 'border-gray-200'
        }`}
        onclick={`selectImage(${index})`}
      >
        {item.type === 'video' ? (
          <img
            src={item.thumbnail}
            alt={`${productName} video thumbnail`}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        ) : (
          <img
            src={item.url && item.url.includes('/solar24h-otm/') && item.url.endsWith('.avif') ? item.url.replace('.avif', '_thumb.avif') : item.url && item.url.includes('/solar24h/') && /\.(jpg|jpeg|png|webp)$/i.test(item.url) ? item.url.replace(/^\/solar24h\//, '/solar24h-otm/').replace(/\.(jpg|jpeg|png|webp)$/i, '_thumb.avif') : item.url}
            alt={`${productName} - ${index + 1}`}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        )}
      </button>
    ))}
  </div>
</div>

<script>
interface Window {
  selectImage: (index: number) => void;
  previousImage: () => void;
  nextImage: () => void;
}

let selectedIndex = 0;
const galleryItems = document.querySelectorAll('[data-index]');
const thumbnails = document.querySelectorAll('.thumbnail');

function updateGallery(newIndex: number) {
  galleryItems.forEach((item, index) => {
    item.classList.toggle('opacity-0', index !== newIndex);
    item.classList.toggle('opacity-100', index === newIndex);
  });

  thumbnails.forEach((thumb, index) => {
    thumb.classList.toggle('border-red-500', index === newIndex);
    thumb.classList.toggle('border-gray-200', index !== newIndex);
  });

  selectedIndex = newIndex;
}

function selectImage(index: number) {
  updateGallery(index);
}

function previousImage() {
  const newIndex = selectedIndex > 0 ? selectedIndex - 1 : galleryItems.length - 1;
  updateGallery(newIndex);
}

function nextImage() {
  const newIndex = selectedIndex < galleryItems.length - 1 ? selectedIndex + 1 : 0;
  updateGallery(newIndex);
}

// Make functions available globally
(window as any).selectImage = selectImage;
(window as any).previousImage = previousImage;
(window as any).nextImage = nextImage;
</script> 