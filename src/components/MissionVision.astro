---
---

<section class="py-20 bg-gradient-to-br from-gray-50 to-blue-50 relative overflow-hidden">
  <!-- Background decorations -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-10 left-10 w-64 h-64 bg-blue-300 rounded-full mix-blend-multiply filter blur-xl animate-pulse"></div>
    <div class="absolute bottom-10 right-10 w-64 h-64 bg-purple-300 rounded-full mix-blend-multiply filter blur-xl animate-pulse"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-green-300 rounded-full mix-blend-multiply filter blur-xl animate-pulse"></div>
  </div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Sứ mệnh & 
        <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
          Tầm nhìn
        </span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Định hướng phát triển và cam kết của SOLAR24H trong hành trình cách mạng hóa 
        hệ thống điện mặt trời của doanh nghiệp Việt Nam
      </p>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      <!-- Mission Card -->
      <div class="group relative">
        <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-purple-600 rounded-3xl blur opacity-25 group-hover:opacity-75 transition duration-1000 group-hover:duration-200"></div>
        <div class="relative bg-white rounded-3xl p-8 lg:p-10 shadow-2xl transform group-hover:scale-105 transition-all duration-300">
          <div class="mb-6">
            <div class="w-16 h-16 bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
            <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">Sứ mệnh</h3>
          </div>
          
          <div class="space-y-6">
            <p class="text-lg text-gray-600 leading-relaxed">
              <strong class="text-blue-600">SOLAR24H</strong> cam kết mang đến những 
              <strong class="text-purple-600">giải pháp điện mặt trời toàn diện</strong> — 
              từ tư vấn, cung cấp thiết bị đến thi công và bảo trì — giúp người dân và 
              doanh nghiệp Việt Nam tiết kiệm chi phí điện và sử dụng năng lượng sạch.
            </p>
            
            <div class="space-y-4">
              <div class="flex items-start space-x-3">
                <div class="w-2 h-2 bg-blue-600 rounded-full mt-3 flex-shrink-0"></div>
                <p class="text-gray-600">Phổ cập điện mặt trời đến mọi gia đình và doanh nghiệp</p>
              </div>
              <div class="flex items-start space-x-3">
                <div class="w-2 h-2 bg-purple-600 rounded-full mt-3 flex-shrink-0"></div>
                <p class="text-gray-600">Cung cấp thiết bị chính hãng, thi công đúng tiêu chuẩn kỹ thuật</p>
              </div>
              <div class="flex items-start space-x-3">
                <div class="w-2 h-2 bg-green-600 rounded-full mt-3 flex-shrink-0"></div>
                <p class="text-gray-600">Góp phần giảm phát thải carbon, bảo vệ môi trường Việt Nam</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Vision Card -->
      <div class="group relative">
        <div class="absolute -inset-1 bg-gradient-to-r from-green-600 to-teal-600 rounded-3xl blur opacity-25 group-hover:opacity-75 transition duration-1000 group-hover:duration-200"></div>
        <div class="relative bg-white rounded-3xl p-8 lg:p-10 shadow-2xl transform group-hover:scale-105 transition-all duration-300">
          <div class="mb-6">
            <div class="w-16 h-16 bg-gradient-to-r from-green-600 to-teal-600 rounded-2xl flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
            </div>
            <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">Tầm nhìn</h3>
          </div>
          
          <div class="space-y-6">
            <p class="text-lg text-gray-600 leading-relaxed">
              Trở thành <strong class="text-green-600">đơn vị hàng đầu</strong> 
              trong lĩnh vực cung cấp và lắp đặt thiết bị điện mặt trời tại Việt Nam vào năm 2030, 
              đồng thời mở rộng ra <strong class="text-teal-600">thị trường Đông Nam Á</strong>.
            </p>
            
            <div class="space-y-4">
              <div class="flex items-start space-x-3">
                <div class="w-2 h-2 bg-green-600 rounded-full mt-3 flex-shrink-0"></div>
                <p class="text-gray-600">Đạt 10.000+ hệ thống điện mặt trời được lắp đặt trên toàn quốc</p>
              </div>
              <div class="flex items-start space-x-3">
                <div class="w-2 h-2 bg-teal-600 rounded-full mt-3 flex-shrink-0"></div>
                <p class="text-gray-600">Xây dựng mạng lưới đại lý và đối tác thi công trên 63 tỉnh thành</p>
              </div>
              <div class="flex items-start space-x-3">
                <div class="w-2 h-2 bg-blue-600 rounded-full mt-3 flex-shrink-0"></div>
                <p class="text-gray-600">Tiên phong ứng dụng công nghệ lưu trữ năng lượng thế hệ mới</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Stats Section -->
    <div class="mt-20 grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="text-center group">
        <div class="w-16 h-16 bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h4 class="text-2xl font-bold text-gray-900 mb-2">Đổi mới</h4>
        <p class="text-gray-600">Luôn đi đầu trong nghiên cứu và phát triển</p>
      </div>
      
      <div class="text-center group">
        <div class="w-16 h-16 bg-gradient-to-r from-green-600 to-teal-600 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h4 class="text-2xl font-bold text-gray-900 mb-2">Chất lượng</h4>
        <p class="text-gray-600">Cam kết về độ bền và hiệu suất vượt trội</p>
      </div>
      
      <div class="text-center group">
        <div class="w-16 h-16 bg-gradient-to-r from-purple-600 to-pink-600 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
        <h4 class="text-2xl font-bold text-gray-900 mb-2">Cộng đồng</h4>
        <p class="text-gray-600">Xây dựng mối quan hệ bền vững với khách hàng</p>
      </div>
      
      <div class="text-center group">
        <div class="w-16 h-16 bg-gradient-to-r from-yellow-600 to-orange-600 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"></path>
          </svg>
        </div>
        <h4 class="text-2xl font-bold text-gray-900 mb-2">Bền vững</h4>
        <p class="text-gray-600">Phát triển theo hướng thân thiện môi trường</p>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  .animate-float-delayed {
    animation: float 6s ease-in-out infinite 2s;
  }
  
  @keyframes float {
    0%, 100% { 
      transform: translateY(0px) rotate(0deg);
    }
    50% { 
      transform: translateY(-20px) rotate(2deg);
    }
  }
</style> 