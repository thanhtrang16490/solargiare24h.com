---
import ThreeCanvas from './islands/ThreeCanvas.tsx';
---

<section class="relative min-h-screen bg-gradient-to-br from-slate-900 via-blue-900 to-purple-900 text-white overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img 
      src="https://images.unsplash.com/photo-1509391366360-2e959784a276?w=2340&q=80" 
      alt="Hệ thống điện mặt trời áp mái"
      class="w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-slate-900/80 via-blue-900/80 to-purple-900/80"></div>
  </div>

  <!-- Hero Content -->
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-16 z-10">
    <div class="text-center">
      <!-- Main Hero Text -->
      <h1 class="text-5xl md:text-7xl font-bold mb-8 leading-tight">
        <span class="block">Chào mừng đến với</span>
        <span class="bg-gradient-to-r from-cyan-400 via-blue-500 to-purple-600 bg-clip-text text-transparent block mt-4">
          SOLAR24H
        </span>
      </h1>
      
      <p class="text-xl md:text-2xl text-gray-300 mb-12 max-w-4xl mx-auto leading-relaxed">
        Chúng tôi không chỉ cung cấp inverter hòa lưới và hệ thống điện mặt trời - chúng tôi tạo ra những hệ thống điện mặt trời thông minh, 
        nơi công nghệ và sự thoải mái hòa quyện để mang lại hiệu suất tối ưu cho mọi doanh nghiệp.
      </p>
      
      <!-- Stats Section -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-bold text-cyan-400 mb-2">500+</div>
          <div class="text-gray-300">Khách hàng doanh nghiệp</div>
        </div>
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-bold text-blue-400 mb-2">5000+</div>
          <div class="text-gray-300">Sản phẩm đã lắp đặt</div>
        </div>
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-bold text-purple-400 mb-2">98%</div>
          <div class="text-gray-300">Khách hàng hài lòng</div>
        </div>
      </div>
      
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-16">
        <button class="group relative bg-gradient-to-r from-cyan-600 to-blue-600 text-white px-10 py-5 rounded-2xl font-bold text-lg shadow-2xl hover:shadow-3xl transition-all duration-300 transform hover:scale-105 overflow-hidden">
          <span class="relative z-10 flex items-center">
            <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
            Khám phá showroom 3D
          </span>
          <div class="absolute inset-0 bg-gradient-to-r from-cyan-700 to-blue-700 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </button>
        
        <button class="group bg-white/10 backdrop-blur-sm text-white px-10 py-5 rounded-2xl font-bold text-lg shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:scale-105 border border-white/20 hover:bg-white/20">
          <span class="flex items-center">
            <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
            Tư vấn miễn phí
          </span>
        </button>
      </div>
    </div>
  </div>
  
  <!-- 3D Visual Section -->
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: 3D Chair Showcase -->
      <div class="text-center lg:text-left">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          Công nghệ solar tiên tiến
        </h2>
        <p class="text-gray-300 mb-8 text-lg">
          Từ thiết kế 3D đến sản xuất thông minh, chúng tôi ứng dụng công nghệ hiện đại nhất 
          để tạo ra những giải pháp hệ thống điện mặt trời hoàn hảo.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <div class="flex items-center text-gray-300">
            <svg class="w-5 h-5 mr-2 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            Thiết kế 3D chuyên nghiệp
          </div>
          <div class="flex items-center text-gray-300">
            <svg class="w-5 h-5 mr-2 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            Công nghệ solar tiên tiến
          </div>
        </div>
      </div>
      
      <!-- Right: Product Image -->
      <div class="relative">
        <img 
          src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1000&q=80" 
          alt="Tấm pin mặt trời"
          class="w-full max-w-md mx-auto rounded-3xl shadow-2xl"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-transparent to-cyan-400/20 rounded-3xl"></div>
      </div>
    </div>
  </div>
  
  <!-- Floating Elements -->
  <div class="absolute top-20 left-20 w-20 h-20 bg-cyan-400/20 rounded-full blur-xl animate-pulse"></div>
  <div class="absolute bottom-20 right-20 w-32 h-32 bg-purple-400/20 rounded-full blur-xl animate-pulse delay-1000"></div>
  <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-40 h-40 bg-blue-400/20 rounded-full blur-xl animate-pulse delay-500"></div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
  }
  
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  .shadow-3xl {
    box-shadow: 0 35px 60px -12px rgba(0, 0, 0, 0.25);
  }
</style> 