---
interface Props {
  product: {
    name: string;
    price: number;
    original_price?: number;
    image_url?: string;
  };
}

const { product } = Astro.props;
import ProductBuyNowIsland from './react/ProductBuyNowIsland';
---

<div
  class="fixed left-0 right-16 bottom-2 z-[10000001] flex justify-center transition-all duration-300 opacity-0 translate-y-8 translate-x-4 pointer-events-none"
  style="width: 100%;"
  id="floatProductAction"
>
  <div class="container mx-auto bg-white border border-gray-200 shadow-lg py-2 rounded-md flex items-center justify-between px-4">
    <div class="flex items-center space-x-4">
      <div class="relative w-12 h-12">
        <img
          src={product.image_url || '/placeholder.png'}
          alt={product.name}
          class="w-full h-full object-contain"
          loading="lazy"
        />
      </div>
      <div>
        <div class="text-red-600 font-bold">
          {new Intl.NumberFormat('vi-VN', {
            style: 'currency',
            currency: 'VND'
          }).format(product.price)}
        </div>
        {product.original_price && (
          <div class="text-gray-500 line-through text-sm">
            {new Intl.NumberFormat('vi-VN', {
              style: 'currency',
              currency: 'VND'
            }).format(product.original_price)}
          </div>
        )}
      </div>
    </div>

    <div class="flex-1 text-center px-4">
      <div class="font-medium text-gray-900 line-clamp-1">
        {product.name}
      </div>
    </div>

    <div class="flex items-center space-x-3">
      <a
        href={import.meta.env.PUBLIC_ZALO_URL || 'https://zalo.me/0979983355'}
        target="_blank"
        rel="noopener nofollow"
        class="px-4 py-2 border border-[#1182FC] text-[#1182FC] rounded hover:bg-blue-50 transition-colors flex items-center gap-2"
        id="floatZaloChat"
      >
        <img src="/images/zalo-2.png" alt="Chat Zalo" class="h-5 w-5 object-contain" />
        Chat Zalo
      </a>
      <ProductBuyNowIsland client:load product={product} />
    </div>
  </div>
</div>

<div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 p-4 md:hidden">
  <div class="flex items-center justify-between">
    <div>
      <div class="text-lg font-bold text-red-600">
        {new Intl.NumberFormat('vi-VN', {
          style: 'currency',
          currency: 'VND'
        }).format(product.price)}
      </div>
    </div>
    <button
      class="bg-red-600 text-white py-2 px-6 rounded-lg font-medium hover:bg-red-700 transition-colors"
      onclick="window.location.href='https://m.me/g3.vn.official'"
    >
      Liên hệ tư vấn
    </button>
  </div>
</div>

<script>
let lastScrollY = window.scrollY;
const floatAction = document.getElementById('floatProductAction');

function handleScroll() {
  if (!floatAction) return;

  const currentScrollY = window.scrollY;
  const scrollingDown = currentScrollY > lastScrollY;
  const scrolledEnough = currentScrollY > 300;

  if (scrolledEnough && !scrollingDown) {
    floatAction.classList.remove('opacity-0', 'translate-y-8', 'pointer-events-none');
    floatAction.classList.add('opacity-100', 'translate-y-0', 'translate-x-4', 'pointer-events-auto');
  } else {
    floatAction.classList.add('opacity-0', 'translate-y-8', 'pointer-events-none');
    floatAction.classList.remove('opacity-100', 'translate-y-0', 'translate-x-4', 'pointer-events-auto');
  }

  lastScrollY = currentScrollY;
}

window.addEventListener('scroll', handleScroll);

// Add to cart functionality
const floatAddToCartBtn = document.getElementById('floatAddToCart');
const floatBuyNowBtn = document.getElementById('floatBuyNow');

if (floatAddToCartBtn) {
  floatAddToCartBtn.addEventListener('click', () => {
    // TODO: Implement add to cart functionality
    console.log('Float add to cart clicked');
  });
}

if (floatBuyNowBtn) {
  floatBuyNowBtn.addEventListener('click', () => {
    // TODO: Implement buy now functionality
    console.log('Float buy now clicked');
  });
}
</script> 