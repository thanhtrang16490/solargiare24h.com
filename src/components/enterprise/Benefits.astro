---
// Benefits section for enterprise landing page
---

<section class="py-16 lg:py-20 bg-gray-50 overflow-hidden">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 lg:mb-16 fade-in-up">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        Lợi ích khi đầu tư 
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-600">
          thiết bị năng lượng mặt trời
        </span>
      </h2>
      <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto">
        Khám phá những lợi ích thiết thực mà thiết bị năng lượng mặt trời mang lại cho doanh nghiệp của bạn
      </p>
    </div>
    
    <!-- Hero Image Section -->
    <div class="mb-12 lg:mb-16 fade-in-up">
      <div class="relative overflow-hidden rounded-2xl lg:rounded-3xl shadow-2xl">
        <img 
          src="https://images.unsplash.com/photo-1497215842964-222b430dc094?w=1200&h=600&fit=crop&crop=center"
          alt="Modern office with solar furniture"
          class="w-full h-64 sm:h-80 lg:h-96 object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-blue-600/80 to-cyan-600/60"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="text-center text-white px-4">
            <h3 class="text-xl sm:text-2xl lg:text-3xl font-bold mb-2 lg:mb-4">Hệ thống điện mặt trời hiện đại</h3>
            <p class="text-base sm:text-lg lg:text-xl max-w-2xl mx-auto">
              Tối ưu hóa năng suất và sức khỏe nhân viên với thiết kế solar
            </p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Benefits Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8 mb-12 lg:mb-16">
      <!-- Benefit 1 -->
      <div class="group bg-white rounded-2xl p-6 lg:p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 fade-in-up benefit-card" data-aos="fade-up" data-aos-delay="100">
        <div class="relative mb-6">
          <div class="w-14 h-14 lg:w-16 lg:h-16 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3">Cải thiện sức khỏe</h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed">
          Giảm tốn điện, căng thẳng cổ vai gáy và các vấn đề về xương khớp do tư thế làm việc không đúng
        </p>
      </div>
      
      <!-- Benefit 2 -->
      <div class="group bg-white rounded-2xl p-6 lg:p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 fade-in-up benefit-card" data-aos="fade-up" data-aos-delay="200">
        <div class="relative mb-6">
          <div class="w-14 h-14 lg:w-16 lg:h-16 bg-gradient-to-br from-green-500 to-green-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3">Tăng năng suất</h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed">
          Cải thiện hiệu suất làm việc lên đến 35% với môi trường làm việc thoải mái và solar
        </p>
      </div>
      
      <!-- Benefit 3 -->
      <div class="group bg-white rounded-2xl p-6 lg:p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 fade-in-up benefit-card" data-aos="fade-up" data-aos-delay="300">
        <div class="relative mb-6">
          <div class="w-14 h-14 lg:w-16 lg:h-16 bg-gradient-to-br from-purple-500 to-purple-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3">Tăng sự hài lòng</h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed">
          Nâng cao tinh thần làm việc và sự hài lòng của nhân viên, giảm tỷ lệ nghỉ việc
        </p>
      </div>
      
      <!-- Benefit 4 -->
      <div class="group bg-white rounded-2xl p-6 lg:p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 fade-in-up benefit-card" data-aos="fade-up" data-aos-delay="400">
        <div class="relative mb-6">
          <div class="w-14 h-14 lg:w-16 lg:h-16 bg-gradient-to-br from-orange-500 to-orange-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3">Tiết kiệm chi phí</h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed">
          Giảm chi phí y tế, nghỉ ốm và tăng ROI từ việc đầu tư vào hệ thống điện mặt trời chất lượng
        </p>
      </div>
    </div>
    
    <!-- Statistics Section -->
    <div class="bg-white rounded-2xl lg:rounded-3xl shadow-xl p-6 lg:p-8 mb-12 lg:mb-16 fade-in-up">
      <h3 class="text-xl sm:text-2xl lg:text-3xl font-bold text-gray-900 text-center mb-8 lg:mb-12">
        Những con số ấn tượng
      </h3>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        <div class="text-center stat-item">
          <div class="text-3xl sm:text-4xl lg:text-5xl font-bold text-blue-600 mb-2">35%</div>
          <div class="text-sm sm:text-base text-gray-600">Tăng năng suất</div>
        </div>
        <div class="text-center stat-item">
          <div class="text-3xl sm:text-4xl lg:text-5xl font-bold text-green-600 mb-2">50%</div>
          <div class="text-sm sm:text-base text-gray-600">Giảm tốn điện</div>
        </div>
        <div class="text-center stat-item">
          <div class="text-3xl sm:text-4xl lg:text-5xl font-bold text-purple-600 mb-2">25%</div>
          <div class="text-sm sm:text-base text-gray-600">Giảm nghỉ ốm</div>
        </div>
        <div class="text-center stat-item">
          <div class="text-3xl sm:text-4xl lg:text-5xl font-bold text-orange-600 mb-2">40%</div>
          <div class="text-sm sm:text-base text-gray-600">Tăng sự hài lòng</div>
        </div>
      </div>
    </div>
    
    <!-- Call to Action -->
    <div class="text-center fade-in-up">
      <h3 class="text-xl sm:text-2xl lg:text-3xl font-bold text-gray-900 mb-4">
        Sẵn sàng chuyển đổi hệ thống điện mặt trời?
      </h3>
      <p class="text-base sm:text-lg text-gray-600 mb-6 lg:mb-8 max-w-2xl mx-auto">
        Liên hệ ngay với chúng tôi để được tư vấn miễn phí về giải pháp thiết bị năng lượng mặt trời
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#quote-form" class="inline-flex items-center justify-center px-6 lg:px-8 py-3 lg:py-4 bg-gradient-to-r from-blue-600 to-blue-700 text-white font-semibold rounded-xl hover:from-blue-700 hover:to-blue-800 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl">
          <span class="mr-2">Nhận báo giá</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        <a href="tel:0962916488" class="inline-flex items-center justify-center px-6 lg:px-8 py-3 lg:py-4 border-2 border-blue-600 text-blue-600 font-semibold rounded-xl hover:bg-blue-50 transition-all duration-300 transform hover:scale-105">
          <span class="mr-2">Gọi ngay</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    0% {
      opacity: 0;
      transform: translateY(30px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes slideInLeft {
    0% {
      opacity: 0;
      transform: translateX(-30px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }
  
  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-5px);
    }
  }
  
  .fade-in-up {
    animation: fadeInUp 0.6s ease-out;
  }
  
  .benefit-card {
    position: relative;
    overflow: hidden;
  }
  
  .benefit-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.6), transparent);
    transition: left 0.5s;
  }
  
  .benefit-card:hover::before {
    left: 100%;
  }
  
  .stat-item {
    animation: slideInLeft 0.6s ease-out;
  }
  
  .stat-item:nth-child(1) { animation-delay: 0.1s; }
  .stat-item:nth-child(2) { animation-delay: 0.2s; }
  .stat-item:nth-child(3) { animation-delay: 0.3s; }
  .stat-item:nth-child(4) { animation-delay: 0.4s; }
  
  /* Mobile specific optimizations */
  @media (max-width: 640px) {
    .benefit-card {
      margin-bottom: 1rem;
    }
    
    .stat-item {
      animation-delay: 0.1s;
    }
  }
  
  /* Hover effects for mobile */
  @media (hover: none) {
    .benefit-card:hover {
      transform: none;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    }
    
    .benefit-card:hover::before {
      left: -100%;
    }
  }
</style>

<script>
  // Intersection Observer for animations
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };
  
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
      }
    });
  }, observerOptions);
  
  // Observe all benefit cards
  document.querySelectorAll('.benefit-card').forEach(card => {
    card.style.opacity = '0';
    card.style.transform = 'translateY(30px)';
    card.style.transition = 'opacity 0.6s ease-out, transform 0.6s ease-out';
    observer.observe(card);
  });
  
  // Observe stat items
  document.querySelectorAll('.stat-item').forEach((item, index) => {
    item.style.opacity = '0';
    item.style.transform = 'translateX(-30px)';
    item.style.transition = `opacity 0.6s ease-out ${index * 0.1}s, transform 0.6s ease-out ${index * 0.1}s`;
    observer.observe(item);
  });
  
  // Counter animation for statistics
  const animateCounter = (element, finalValue) => {
    let currentValue = 0;
    const increment = finalValue / 50;
    const timer = setInterval(() => {
      currentValue += increment;
      if (currentValue >= finalValue) {
        currentValue = finalValue;
        clearInterval(timer);
      }
      element.textContent = Math.floor(currentValue) + '%';
    }, 30);
  };
  
  // Animate statistics when they come into view
  const statsObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const statItems = entry.target.querySelectorAll('.stat-item');
        statItems.forEach((item, index) => {
          const numberElement = item.querySelector('div:first-child');
          const value = parseInt(numberElement.textContent);
          setTimeout(() => {
            animateCounter(numberElement, value);
          }, index * 200);
        });
        statsObserver.unobserve(entry.target);
      }
    });
  }, observerOptions);
  
  const statsSection = document.querySelector('.bg-white.rounded-2xl');
  if (statsSection) {
    statsObserver.observe(statsSection);
  }
</script> 