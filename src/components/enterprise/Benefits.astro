---
// Benefits section — solar enterprise
---

<section class="py-16 lg:py-20 bg-gray-50 overflow-hidden">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-12 lg:mb-16">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        Lợi ích khi đầu tư
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-500 to-orange-500">
          điện mặt trời doanh nghiệp
        </span>
      </h2>
      <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto">
        Hệ thống điện mặt trời quy mô lớn mang lại lợi ích tài chính và môi trường bền vững cho doanh nghiệp
      </p>
    </div>

    <!-- Hero image -->
    <div class="mb-12 lg:mb-16">
      <div class="relative overflow-hidden rounded-2xl lg:rounded-3xl shadow-2xl">
        <img
          src="https://images.unsplash.com/photo-1508514177221-188b1cf16e9d?w=1200&h=500&fit=crop&crop=center"
          alt="Hệ thống điện mặt trời mái nhà xưởng công nghiệp"
          class="w-full h-64 sm:h-80 lg:h-96 object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-yellow-600/70 to-orange-600/50"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="text-center text-white px-4">
            <h3 class="text-xl sm:text-2xl lg:text-3xl font-bold mb-2 lg:mb-4">Điện mặt trời công nghiệp & thương mại</h3>
            <p class="text-base sm:text-lg lg:text-xl max-w-2xl mx-auto">
              Giải pháp tối ưu cho nhà máy, kho xưởng, tòa nhà văn phòng và khu công nghiệp
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Benefits grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8 mb-12 lg:mb-16">
      <div class="group bg-white rounded-2xl p-6 lg:p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 benefit-card">
        <div class="w-14 h-14 lg:w-16 lg:h-16 bg-gradient-to-br from-yellow-500 to-orange-500 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3">Tiết kiệm 70–90% tiền điện</h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed">
          Giảm mạnh chi phí vận hành, tăng lợi nhuận và khả năng cạnh tranh của doanh nghiệp
        </p>
      </div>

      <div class="group bg-white rounded-2xl p-6 lg:p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 benefit-card">
        <div class="w-14 h-14 lg:w-16 lg:h-16 bg-gradient-to-br from-green-500 to-emerald-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3">Chủ động nguồn điện 24/7</h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed">
          Inverter hybrid + lưu trữ ắc quy đảm bảo sản xuất liên tục, không gián đoạn khi mất điện lưới
        </p>
      </div>

      <div class="group bg-white rounded-2xl p-6 lg:p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 benefit-card">
        <div class="w-14 h-14 lg:w-16 lg:h-16 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3">Giảm phát thải CO₂</h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed">
          Đáp ứng tiêu chuẩn ESG, tăng uy tín thương hiệu và đáp ứng yêu cầu xuất khẩu xanh
        </p>
      </div>

      <div class="group bg-white rounded-2xl p-6 lg:p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 benefit-card">
        <div class="w-14 h-14 lg:w-16 lg:h-16 bg-gradient-to-br from-purple-500 to-purple-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3">Hoàn vốn 4–6 năm</h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed">
          Đầu tư một lần, sinh lời 25+ năm. ROI hấp dẫn với hỗ trợ vay vốn ưu đãi từ ngân hàng
        </p>
      </div>
    </div>

    <!-- Stats -->
    <div class="bg-white rounded-2xl lg:rounded-3xl shadow-xl p-6 lg:p-8 mb-12 lg:mb-16">
      <h3 class="text-xl sm:text-2xl lg:text-3xl font-bold text-gray-900 text-center mb-8 lg:mb-12">
        Những con số thực tế
      </h3>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        <div class="text-center stat-item">
          <div class="text-3xl sm:text-4xl lg:text-5xl font-bold text-yellow-500 mb-2">90%</div>
          <div class="text-sm sm:text-base text-gray-600">Tiết kiệm tiền điện</div>
        </div>
        <div class="text-center stat-item">
          <div class="text-3xl sm:text-4xl lg:text-5xl font-bold text-green-600 mb-2">25 năm</div>
          <div class="text-sm sm:text-base text-gray-600">Tuổi thọ hệ thống</div>
        </div>
        <div class="text-center stat-item">
          <div class="text-3xl sm:text-4xl lg:text-5xl font-bold text-blue-600 mb-2">300+</div>
          <div class="text-sm sm:text-base text-gray-600">Dự án đã triển khai</div>
        </div>
        <div class="text-center stat-item">
          <div class="text-3xl sm:text-4xl lg:text-5xl font-bold text-purple-600 mb-2">50MWp</div>
          <div class="text-sm sm:text-base text-gray-600">Tổng công suất lắp đặt</div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center">
      <h3 class="text-xl sm:text-2xl lg:text-3xl font-bold text-gray-900 mb-4">
        Sẵn sàng chuyển sang năng lượng sạch?
      </h3>
      <p class="text-base sm:text-lg text-gray-600 mb-6 lg:mb-8 max-w-2xl mx-auto">
        Liên hệ ngay để được khảo sát miễn phí và nhận báo giá chi tiết cho dự án của bạn
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#quote-form" class="inline-flex items-center justify-center px-6 lg:px-8 py-3 lg:py-4 bg-gradient-to-r from-yellow-500 to-orange-500 text-white font-semibold rounded-xl hover:from-yellow-600 hover:to-orange-600 transition-all duration-300 transform hover:scale-105 shadow-lg">
          <span class="mr-2">Nhận báo giá</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        <a href="tel:0962916488" class="inline-flex items-center justify-center px-6 lg:px-8 py-3 lg:py-4 border-2 border-yellow-500 text-yellow-600 font-semibold rounded-xl hover:bg-yellow-50 transition-all duration-300 transform hover:scale-105">
          <span class="mr-2">Gọi ngay: 0962 916 488</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .benefit-card { opacity: 0; transform: translateY(30px); transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
  .stat-item { opacity: 0; transform: translateX(-20px); transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).style.opacity = '1';
        (entry.target as HTMLElement).style.transform = 'none';
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.benefit-card, .stat-item').forEach(el => observer.observe(el));
</script>
