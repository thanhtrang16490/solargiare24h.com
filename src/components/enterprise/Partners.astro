---
// Partners section — solar enterprise
---

<section class="py-20 bg-gray-50">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
        Đối tác & khách hàng
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-500 to-orange-500">
          tin tưởng
        </span>
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Hàng trăm doanh nghiệp, nhà máy và khu công nghiệp đã tin tưởng lựa chọn SOLAR24H
      </p>
    </div>

    <!-- Partner logos -->
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-6 mb-16">
      {[
        { abbr: 'EVN', name: 'Điện lực VN' },
        { abbr: 'PVN', name: 'Petrovietnam' },
        { abbr: 'VCB', name: 'Vietcombank' },
        { abbr: 'FPT', name: 'FPT Corp' },
        { abbr: 'VIN', name: 'VinGroup' },
        { abbr: 'TCB', name: 'Techcombank' },
      ].map(p => (
        <div class="bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow duration-300 flex items-center justify-center">
          <div class="text-gray-500 text-center">
            <div class="text-2xl font-bold mb-1">{p.abbr}</div>
            <div class="text-xs">{p.name}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Testimonials -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="bg-white rounded-2xl p-8 shadow-lg">
        <div class="flex items-center mb-6">
          <div class="w-12 h-12 bg-gradient-to-r from-yellow-500 to-orange-500 rounded-full flex items-center justify-center text-white font-bold text-lg">H</div>
          <div class="ml-4">
            <div class="font-semibold text-gray-900">Phạm Minh Hùng</div>
            <div class="text-sm text-gray-500">Giám đốc Kỹ thuật — Công ty CP Sản xuất Thực phẩm Sài Gòn</div>
          </div>
        </div>
        <blockquote class="text-gray-700 text-lg leading-relaxed mb-6">
          "Sau khi lắp hệ thống 500kWp, hóa đơn điện nhà máy giảm từ 280 triệu xuống còn 35 triệu/tháng. SOLAR24H thi công đúng tiến độ, đội kỹ thuật chuyên nghiệp và hỗ trợ sau bán hàng rất tốt."
        </blockquote>
        <div class="flex items-center">
          {[...Array(5)].map(() => (
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
          ))}
          <span class="ml-2 text-sm text-gray-500">5.0/5</span>
        </div>
      </div>

      <div class="bg-white rounded-2xl p-8 shadow-lg">
        <div class="flex items-center mb-6">
          <div class="w-12 h-12 bg-gradient-to-r from-green-500 to-emerald-500 rounded-full flex items-center justify-center text-white font-bold text-lg">L</div>
          <div class="ml-4">
            <div class="font-semibold text-gray-900">Lê Thị Hồng Linh</div>
            <div class="text-sm text-gray-500">Tổng Giám đốc — Khu công nghiệp Bình Dương Xanh</div>
          </div>
        </div>
        <blockquote class="text-gray-700 text-lg leading-relaxed mb-6">
          "Dự án 2MWp cho khu công nghiệp được SOLAR24H hoàn thành trong 45 ngày. Hệ thống giám sát từ xa rất tiện lợi, chúng tôi theo dõi sản lượng theo thời gian thực. Đây là khoản đầu tư sinh lời nhất trong 5 năm qua."
        </blockquote>
        <div class="flex items-center">
          {[...Array(5)].map(() => (
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
          ))}
          <span class="ml-2 text-sm text-gray-500">5.0/5</span>
        </div>
      </div>
    </div>

    <!-- Stats banner -->
    <div class="mt-16 bg-gradient-to-r from-yellow-500 to-orange-500 rounded-2xl p-8 text-center">
      <h3 class="text-2xl font-bold text-white mb-8">Những con số ấn tượng</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {[
          { val: '300+', label: 'Dự án', sub: 'đã triển khai' },
          { val: '50MWp+', label: 'Công suất', sub: 'lắp đặt' },
          { val: '98%', label: 'Khách hàng', sub: 'hài lòng' },
          { val: '24/7', label: 'Hỗ trợ', sub: 'kỹ thuật' },
        ].map(s => (
          <div class="text-center">
            <div class="text-4xl font-bold text-white mb-2">{s.val}</div>
            <div class="text-yellow-100">{s.label}</div>
            <div class="text-yellow-100 text-sm">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Case study -->
    <div class="mt-16 bg-white rounded-2xl p-8 shadow-lg">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">
            Case Study: Nhà máy dệt may Bình Dương — 1MWp
          </h3>
          <p class="text-gray-600 mb-6">
            Lắp đặt hệ thống 1MWp trên mái nhà xưởng 8.000m². Tiết kiệm 85% chi phí điện, hoàn vốn sau 5 năm, giảm 800 tấn CO₂/năm.
          </p>
          <div class="space-y-3">
            <div class="flex items-center">
              <div class="w-2 h-2 bg-yellow-500 rounded-full mr-3"></div>
              <span class="text-gray-700">Thời gian thi công: 30 ngày</span>
            </div>
            <div class="flex items-center">
              <div class="w-2 h-2 bg-yellow-500 rounded-full mr-3"></div>
              <span class="text-gray-700">Tiết kiệm điện: 1.200.000 kWh/năm</span>
            </div>
            <div class="flex items-center">
              <div class="w-2 h-2 bg-yellow-500 rounded-full mr-3"></div>
              <span class="text-gray-700">Giảm chi phí điện: ~1,5 tỷ đồng/năm</span>
            </div>
            <div class="flex items-center">
              <div class="w-2 h-2 bg-yellow-500 rounded-full mr-3"></div>
              <span class="text-gray-700">Giảm phát thải: 800 tấn CO₂/năm</span>
            </div>
          </div>
          <a
            href="#quote-form"
            class="inline-flex items-center mt-6 px-6 py-3 rounded-xl bg-gradient-to-r from-yellow-500 to-orange-500 text-white font-semibold hover:from-yellow-600 hover:to-orange-600 transition-all duration-300 transform hover:scale-105"
          >
            Nhận báo giá dự án tương tự
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
        <div class="relative">
          <div class="grid grid-cols-2 gap-4">
            <div class="col-span-2 relative overflow-hidden rounded-xl shadow-lg">
              <img
                src="https://images.unsplash.com/photo-1509391366360-2e959784a276?w=600&h=300&fit=crop&crop=center"
                alt="Hệ thống điện mặt trời 1MWp nhà máy dệt may"
                class="w-full h-48 object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
              <div class="absolute bottom-4 left-4 text-white">
                <div class="text-lg font-semibold">1MWp — Nhà máy dệt may</div>
                <div class="text-sm text-gray-300">Bình Dương, 2024</div>
              </div>
            </div>
            <div class="relative overflow-hidden rounded-xl shadow-lg">
              <img
                src="https://images.unsplash.com/photo-1508514177221-188b1cf16e9d?w=300&h=200&fit=crop&crop=center"
                alt="Tấm pin mặt trời trên mái nhà xưởng"
                class="w-full h-32 object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
              <div class="absolute bottom-2 left-2 text-white text-sm font-medium">Tấm pin mono PERC</div>
            </div>
            <div class="relative overflow-hidden rounded-xl shadow-lg">
              <img
                src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=300&h=200&fit=crop&crop=center"
                alt="Inverter hybrid công nghiệp"
                class="w-full h-32 object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
              <div class="absolute bottom-2 left-2 text-white text-sm font-medium">Inverter công nghiệp</div>
            </div>
          </div>
          <div class="absolute -top-4 -right-4 bg-green-500 text-white px-4 py-2 rounded-full text-sm font-semibold shadow-lg">
            Hoàn thành 100%
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
