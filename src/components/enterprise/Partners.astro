---
// Partners section for enterprise landing page
---

<section class="py-20 bg-gray-50">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
        Đối tác & khách hàng 
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-600">
          tin tưởng
        </span>
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Hàng trăm doanh nghiệp đã tin tưởng lựa chọn giải pháp thiết bị năng lượng mặt trời của chúng tôi
      </p>
    </div>
    
    <!-- Partners Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-8 mb-16">
      <!-- Partner logos (using placeholder for demo) -->
      <div class="bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow duration-300 flex items-center justify-center">
        <div class="text-gray-400 text-center">
          <div class="text-2xl font-bold mb-1">VTP</div>
          <div class="text-xs">Viettel Post</div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow duration-300 flex items-center justify-center">
        <div class="text-gray-400 text-center">
          <div class="text-2xl font-bold mb-1">FPT</div>
          <div class="text-xs">Software</div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow duration-300 flex items-center justify-center">
        <div class="text-gray-400 text-center">
          <div class="text-2xl font-bold mb-1">VNP</div>
          <div class="text-xs">VinGroup</div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow duration-300 flex items-center justify-center">
        <div class="text-gray-400 text-center">
          <div class="text-2xl font-bold mb-1">TCB</div>
          <div class="text-xs">Techcombank</div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow duration-300 flex items-center justify-center">
        <div class="text-gray-400 text-center">
          <div class="text-2xl font-bold mb-1">PVN</div>
          <div class="text-xs">Petrovietnam</div>
        </div>
      </div>
      
      <div class="bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow duration-300 flex items-center justify-center">
        <div class="text-gray-400 text-center">
          <div class="text-2xl font-bold mb-1">VCB</div>
          <div class="text-xs">Vietcombank</div>
        </div>
      </div>
    </div>
    
    <!-- Testimonials -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Testimonial 1 -->
      <div class="bg-white rounded-2xl p-8 shadow-lg">
        <div class="flex items-center mb-6">
          <div class="w-12 h-12 bg-gradient-to-r from-blue-500 to-cyan-500 rounded-full flex items-center justify-center text-white font-bold text-lg">
            H
          </div>
          <div class="ml-4">
            <div class="font-semibold text-gray-900">Phạm Minh Hùng</div>
            <div class="text-sm text-gray-500">Giám đốc Nhân sự - Công ty TNHH Công nghệ Saigon</div>
          </div>
        </div>
        <blockquote class="text-gray-700 text-lg leading-relaxed mb-6">
          "Hệ thống điện mặt trời mới đã cải thiện rõ rệt sự hài lòng của nhân viên. Tỷ lệ nghỉ phép vì tốn điện giảm 60% so với trước đây. Đây thực sự là một khoản đầu tư đáng giá."
        </blockquote>
        <div class="flex items-center">
          <div class="flex space-x-1">
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
          </div>
          <span class="ml-2 text-sm text-gray-500">5.0/5</span>
        </div>
      </div>
      
      <!-- Testimonial 2 -->
      <div class="bg-white rounded-2xl p-8 shadow-lg">
        <div class="flex items-center mb-6">
          <div class="w-12 h-12 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white font-bold text-lg">
            L
          </div>
          <div class="ml-4">
            <div class="font-semibold text-gray-900">Lê Thị Hồng Linh</div>
            <div class="text-sm text-gray-500">Tổng Giám đốc - Công ty CP Đầu tư Phát triển Hà Nội</div>
          </div>
        </div>
        <blockquote class="text-gray-700 text-lg leading-relaxed mb-6">
          "Dịch vụ tư vấn và thiết kế rất chuyên nghiệp. Team G3 hiểu rõ nhu cầu doanh nghiệp, đưa ra giải pháp tối ưu cả về chi phí và hiệu quả. Chúng tôi rất hài lòng với quyết định này."
        </blockquote>
        <div class="flex items-center">
          <div class="flex space-x-1">
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
          </div>
          <span class="ml-2 text-sm text-gray-500">5.0/5</span>
        </div>
      </div>
    </div>
    
    <!-- Statistics -->
    <div class="mt-16 bg-gradient-to-r from-blue-600 to-cyan-600 rounded-2xl p-8 text-center">
      <h3 class="text-2xl font-bold text-white mb-8">
        Những con số ấn tượng
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="text-4xl font-bold text-white mb-2">500+</div>
          <div class="text-blue-100">Doanh nghiệp</div>
          <div class="text-blue-100 text-sm">đã tin tưởng</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-white mb-2">10,000+</div>
          <div class="text-blue-100">Nhân viên</div>
          <div class="text-blue-100 text-sm">được trang bị</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-white mb-2">98%</div>
          <div class="text-blue-100">Khách hàng</div>
          <div class="text-blue-100 text-sm">hài lòng</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-white mb-2">24/7</div>
          <div class="text-blue-100">Hỗ trợ</div>
          <div class="text-blue-100 text-sm">bảo hành</div>
        </div>
      </div>
    </div>
    
    <!-- Case Study Preview -->
    <div class="mt-16 bg-white rounded-2xl p-8 shadow-lg">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">
            Case Study: Tập đoàn Đầu tư Phát triển Việt Nam
          </h3>
          <p class="text-gray-600 mb-6">
            Tối ưu hệ thống điện mặt trời cho 200 nhân viên, giảm 40% chi phí y tế do bệnh nghề nghiệp, tăng 25% năng suất làm việc.
          </p>
          <div class="space-y-3">
            <div class="flex items-center">
              <div class="w-2 h-2 bg-green-500 rounded-full mr-3"></div>
              <span class="text-gray-700">Thời gian triển khai: 3 tuần</span>
            </div>
            <div class="flex items-center">
              <div class="w-2 h-2 bg-green-500 rounded-full mr-3"></div>
              <span class="text-gray-700">Tiết kiệm chi phí y tế: 40%</span>
            </div>
            <div class="flex items-center">
              <div class="w-2 h-2 bg-green-500 rounded-full mr-3"></div>
              <span class="text-gray-700">Tăng năng suất: 25%</span>
            </div>
          </div>
          <a 
            href="#quote-form" 
            class="inline-flex items-center mt-6 px-6 py-3 rounded-xl bg-gradient-to-r from-blue-600 to-blue-700 text-white font-semibold hover:from-blue-700 hover:to-blue-800 transition-all duration-300 transform hover:scale-105"
          >
            Xem chi tiết case study
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
        <div class="relative">
          <div class="grid grid-cols-2 gap-4">
            <!-- Main office image -->
            <div class="col-span-2 relative overflow-hidden rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105">
              <img 
                src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=600&h=300&fit=crop&crop=center"
                alt="Modern office hệ thống solar after renovation"
                class="w-full h-48 object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
              <div class="absolute bottom-4 left-4 text-white">
                <div class="text-lg font-semibold">Điện mặt trời hiện đại</div>
                <div class="text-sm text-gray-300">Thiết kế hệ thống điện mặt trời tối ưu</div>
              </div>
            </div>
            
            <!-- Before/After comparison -->
            <div class="relative overflow-hidden rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105">
              <img 
                src="https://images.unsplash.com/photo-1497366754035-f200968a6e72?w=300&h=200&fit=crop&crop=center"
                alt="Solar workstation setup"
                class="w-full h-32 object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
              <div class="absolute bottom-2 left-2 text-white text-sm font-medium">
                Thiết bị điện mặt trời
              </div>
            </div>
            
            <div class="relative overflow-hidden rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105">
              <img 
                src="https://images.unsplash.com/photo-1568992687947-868a62a9f521?w=300&h=200&fit=crop&crop=center"
                alt="Height adjustable desk in modern office"
                class="w-full h-32 object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
              <div class="absolute bottom-2 left-2 text-white text-sm font-medium">
                Inverter hybrid điện
              </div>
            </div>
          </div>
          
          <!-- Success metrics overlay -->
          <div class="absolute -top-4 -right-4 bg-green-500 text-white px-4 py-2 rounded-full text-sm font-semibold shadow-lg">
            Thành công 100%
          </div>
        </div>
      </div>
    </div>
  </div>
</section> 