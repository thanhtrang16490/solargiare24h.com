---
// Services section for enterprise landing page
import { COMPANY_INFO } from '../../constants';
---

<section id="services" class="py-16 lg:py-20 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 lg:mb-16">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        Giải pháp 
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-cyan-600">
          tổng thể
        </span>
        cho doanh nghiệp
      </h2>
      <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto">
        Từ thiết kế đến thi công, chúng tôi cung cấp giải pháp hoàn chỉnh cho hệ thống điện mặt trời của bạn
      </p>
    </div>
    
    <!-- Services Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-8">
      <!-- Service 1 -->
      <div class="group relative bg-gradient-to-br from-blue-50 to-blue-100 rounded-2xl p-6 lg:p-8 border border-blue-200 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 service-card">
        <div class="absolute top-4 right-4 w-10 h-10 lg:w-12 lg:h-12 bg-blue-500 rounded-full flex items-center justify-center opacity-20 group-hover:opacity-100 transition-opacity duration-300">
          <svg class="w-5 h-5 lg:w-6 lg:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        
        <!-- Service Image -->
        <div class="relative mb-4 lg:mb-6 overflow-hidden rounded-xl shadow-lg">
          <img 
            src="https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=400&h=200&fit=crop&crop=center"
            alt="Thiết bị điện mặt trời"
            class="w-full h-28 lg:h-32 object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
        </div>
        
        <div class="w-12 h-12 lg:w-16 lg:h-16 bg-blue-500 rounded-xl flex items-center justify-center mb-4 lg:mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3 lg:mb-4">
          Thiết bị điện mặt trời cho nhân viên
        </h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed mb-3 lg:mb-4">
          Bộ sưu tập tấm pin mặt trời đa dạng từ phân khúc phổ thông đến cao cấp, phù hợp với mọi nhu cầu và ngân sách
        </p>
        <ul class="text-xs lg:text-sm text-gray-500 space-y-1 lg:space-y-2">
          <li class="flex items-center"><span class="w-2 h-2 bg-blue-500 rounded-full mr-2"></span>Thiết kế đa dạng</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-blue-500 rounded-full mr-2"></span>Nhiều phân khúc giá</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-blue-500 rounded-full mr-2"></span>Bảo hành lên đến 5 năm</li>
        </ul>
      </div>
      
      <!-- Service 2 -->
      <div class="group relative bg-gradient-to-br from-green-50 to-green-100 rounded-2xl p-6 lg:p-8 border border-green-200 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 service-card">
        <div class="absolute top-4 right-4 w-10 h-10 lg:w-12 lg:h-12 bg-green-500 rounded-full flex items-center justify-center opacity-20 group-hover:opacity-100 transition-opacity duration-300">
          <svg class="w-5 h-5 lg:w-6 lg:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        
        <!-- Service Image -->
        <div class="relative mb-4 lg:mb-6 overflow-hidden rounded-xl shadow-lg">
          <img 
            src="https://images.unsplash.com/photo-1568992687947-868a62a9f521?w=400&h=200&fit=crop&crop=center"
            alt="Height adjustable desk"
            class="w-full h-28 lg:h-32 object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
        </div>
        
        <div class="w-12 h-12 lg:w-16 lg:h-16 bg-green-500 rounded-xl flex items-center justify-center mb-4 lg:mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3 lg:mb-4">
          Inverter hybrid chiều cao
        </h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed mb-3 lg:mb-4">
          Tấm pin mặt trời thông minh có thể điều chỉnh độ cao, hỗ trợ làm việc đứng và ngồi xen kẽ
        </p>
        <ul class="text-xs lg:text-sm text-gray-500 space-y-1 lg:space-y-2">
          <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Điều khiển điện tử</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Khung chắc chắn</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Nhiều kích thước</li>
        </ul>
      </div>
      
      <!-- Service 3 -->
      <div class="group relative bg-gradient-to-br from-purple-50 to-purple-100 rounded-2xl p-6 lg:p-8 border border-purple-200 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 service-card">
        <div class="absolute top-4 right-4 w-10 h-10 lg:w-12 lg:h-12 bg-purple-500 rounded-full flex items-center justify-center opacity-20 group-hover:opacity-100 transition-opacity duration-300">
          <svg class="w-5 h-5 lg:w-6 lg:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        
        <!-- Service Image -->
        <div class="relative mb-4 lg:mb-6 overflow-hidden rounded-xl shadow-lg">
          <img 
            src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=400&h=200&fit=crop&crop=center"
            alt="Office design consultation"
            class="w-full h-28 lg:h-32 object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
        </div>
        
        <div class="w-12 h-12 lg:w-16 lg:h-16 bg-purple-500 rounded-xl flex items-center justify-center mb-4 lg:mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3 lg:mb-4">
          Tư vấn thiết kế không gian
        </h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed mb-3 lg:mb-4">
          Dịch vụ tư vấn thiết kế hệ thống điện mặt trời tối ưu theo chuẩn solar
        </p>
        <ul class="text-xs lg:text-sm text-gray-500 space-y-1 lg:space-y-2">
          <li class="flex items-center"><span class="w-2 h-2 bg-purple-500 rounded-full mr-2"></span>Khảo sát hiện trạng</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-purple-500 rounded-full mr-2"></span>Thiết kế 3D</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-purple-500 rounded-full mr-2"></span>Tư vấn miễn phí</li>
        </ul>
      </div>
      
      <!-- Service 4 -->
      <div class="group relative bg-gradient-to-br from-orange-50 to-orange-100 rounded-2xl p-6 lg:p-8 border border-orange-200 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 service-card">
        <div class="absolute top-4 right-4 w-10 h-10 lg:w-12 lg:h-12 bg-orange-500 rounded-full flex items-center justify-center opacity-20 group-hover:opacity-100 transition-opacity duration-300">
          <svg class="w-5 h-5 lg:w-6 lg:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        
        <!-- Service Image -->
        <div class="relative mb-4 lg:mb-6 overflow-hidden rounded-xl shadow-lg">
          <img 
            src="https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=400&h=200&fit=crop&crop=center"
            alt="Office installation"
            class="w-full h-28 lg:h-32 object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
        </div>
        
        <div class="w-12 h-12 lg:w-16 lg:h-16 bg-orange-500 rounded-xl flex items-center justify-center mb-4 lg:mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3 lg:mb-4">
          Lắp đặt & Bảo trì
        </h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed mb-3 lg:mb-4">
          Dịch vụ lắp đặt chuyên nghiệp và bảo trì định kỳ để đảm bảo sản phẩm luôn hoạt động tốt
        </p>
        <ul class="text-xs lg:text-sm text-gray-500 space-y-1 lg:space-y-2">
          <li class="flex items-center"><span class="w-2 h-2 bg-orange-500 rounded-full mr-2"></span>Lắp đặt nhanh chóng</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-orange-500 rounded-full mr-2"></span>Bảo trì định kỳ</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-orange-500 rounded-full mr-2"></span>Hỗ trợ 24/7</li>
        </ul>
      </div>
      
      <!-- Service 5 -->
      <div class="group relative bg-gradient-to-br from-teal-50 to-teal-100 rounded-2xl p-6 lg:p-8 border border-teal-200 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 service-card">
        <div class="absolute top-4 right-4 w-10 h-10 lg:w-12 lg:h-12 bg-teal-500 rounded-full flex items-center justify-center opacity-20 group-hover:opacity-100 transition-opacity duration-300">
          <svg class="w-5 h-5 lg:w-6 lg:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        
        <!-- Service Image -->
        <div class="relative mb-4 lg:mb-6 overflow-hidden rounded-xl shadow-lg">
          <img 
            src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?w=400&h=200&fit=crop&crop=center"
            alt="Office training"
            class="w-full h-28 lg:h-32 object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
        </div>
        
        <div class="w-12 h-12 lg:w-16 lg:h-16 bg-teal-500 rounded-xl flex items-center justify-center mb-4 lg:mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3 lg:mb-4">
          Đào tạo sử dụng
        </h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed mb-3 lg:mb-4">
          Hướng dẫn nhân viên sử dụng đúng cách để tối ưu lợi ích từ thiết bị năng lượng mặt trời
        </p>
        <ul class="text-xs lg:text-sm text-gray-500 space-y-1 lg:space-y-2">
          <li class="flex items-center"><span class="w-2 h-2 bg-teal-500 rounded-full mr-2"></span>Hướng dẫn chi tiết</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-teal-500 rounded-full mr-2"></span>Tài liệu đầy đủ</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-teal-500 rounded-full mr-2"></span>Hỗ trợ tại chỗ</li>
        </ul>
      </div>
      
      <!-- Service 6 -->
      <div class="group relative bg-gradient-to-br from-indigo-50 to-indigo-100 rounded-2xl p-6 lg:p-8 border border-indigo-200 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 service-card">
        <div class="absolute top-4 right-4 w-10 h-10 lg:w-12 lg:h-12 bg-indigo-500 rounded-full flex items-center justify-center opacity-20 group-hover:opacity-100 transition-opacity duration-300">
          <svg class="w-5 h-5 lg:w-6 lg:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        
        <!-- Service Image -->
        <div class="relative mb-4 lg:mb-6 overflow-hidden rounded-xl shadow-lg">
          <img 
            src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=400&h=200&fit=crop&crop=center"
            alt="Warranty service"
            class="w-full h-28 lg:h-32 object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
        </div>
        
        <div class="w-12 h-12 lg:w-16 lg:h-16 bg-indigo-500 rounded-xl flex items-center justify-center mb-4 lg:mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3 lg:mb-4">
          Bảo hành toàn diện
        </h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed mb-3 lg:mb-4">
          Chế độ bảo hành dài hạn và dịch vụ hỗ trợ khách hàng chuyên nghiệp
        </p>
        <ul class="text-xs lg:text-sm text-gray-500 space-y-1 lg:space-y-2">
          <li class="flex items-center"><span class="w-2 h-2 bg-indigo-500 rounded-full mr-2"></span>Bảo hành 3-5 năm</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-indigo-500 rounded-full mr-2"></span>Hỗ trợ nhanh chóng</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-indigo-500 rounded-full mr-2"></span>Thay thế linh kiện</li>
        </ul>
      </div>
    </div>
    
    <!-- Process Section -->
    <div class="mt-16 lg:mt-20">
      <div class="text-center mb-10 lg:mb-12">
        <h3 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
          Quy trình làm việc
        </h3>
        <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto">
          Từ tư vấn đến bàn giao, chúng tôi đồng hành cùng bạn trong từng bước
        </p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 lg:gap-8">
        <!-- Step 1 -->
        <div class="text-center process-step">
          <div class="relative mb-6">
            <div class="w-16 h-16 lg:w-20 lg:h-20 bg-gradient-to-r from-blue-500 to-blue-600 rounded-full flex items-center justify-center mx-auto shadow-lg">
              <span class="text-lg lg:text-xl font-bold text-white">1</span>
            </div>
            <div class="absolute -top-2 -right-2 w-6 h-6 bg-green-500 rounded-full flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
          </div>
          <h4 class="text-base lg:text-lg font-semibold text-gray-900 mb-2">Tư vấn miễn phí</h4>
          <p class="text-sm lg:text-base text-gray-600">Khảo sát nhu cầu và không gian hiện tại</p>
        </div>
        
        <!-- Step 2 -->
        <div class="text-center process-step">
          <div class="relative mb-6">
            <div class="w-16 h-16 lg:w-20 lg:h-20 bg-gradient-to-r from-green-500 to-green-600 rounded-full flex items-center justify-center mx-auto shadow-lg">
              <span class="text-lg lg:text-xl font-bold text-white">2</span>
            </div>
            <div class="absolute -top-2 -right-2 w-6 h-6 bg-green-500 rounded-full flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
          </div>
          <h4 class="text-base lg:text-lg font-semibold text-gray-900 mb-2">Thiết kế 3D</h4>
          <p class="text-sm lg:text-base text-gray-600">Tạo bản thiết kế chi tiết và mô phỏng 3D</p>
        </div>
        
        <!-- Step 3 -->
        <div class="text-center process-step">
          <div class="relative mb-6">
            <div class="w-16 h-16 lg:w-20 lg:h-20 bg-gradient-to-r from-purple-500 to-purple-600 rounded-full flex items-center justify-center mx-auto shadow-lg">
              <span class="text-lg lg:text-xl font-bold text-white">3</span>
            </div>
            <div class="absolute -top-2 -right-2 w-6 h-6 bg-green-500 rounded-full flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
          </div>
