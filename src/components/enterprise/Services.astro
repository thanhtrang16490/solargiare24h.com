---
// Services section — solar enterprise
import { COMPANY_INFO } from '../../constants';
---

<section id="services" class="py-16 lg:py-20 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-12 lg:mb-16">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
        Giải pháp
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-500 to-orange-500">
          trọn gói
        </span>
        cho doanh nghiệp
      </h2>
      <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto">
        Từ khảo sát đến vận hành, SOLAR24H đồng hành cùng bạn trong toàn bộ vòng đời dự án
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-8">
      <!-- 1 -->
      <div class="group relative bg-gradient-to-br from-yellow-50 to-orange-50 rounded-2xl p-6 lg:p-8 border border-yellow-200 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 service-card">
        <div class="relative mb-4 lg:mb-6 overflow-hidden rounded-xl shadow-lg">
          <img
            src="https://images.unsplash.com/photo-1509391366360-2e959784a276?w=400&h=200&fit=crop&crop=center"
            alt="Tấm pin mặt trời công nghiệp"
            class="w-full h-28 lg:h-32 object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
        </div>
        <div class="w-12 h-12 lg:w-16 lg:h-16 bg-yellow-500 rounded-xl flex items-center justify-center mb-4 lg:mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3 lg:mb-4">Hệ thống hòa lưới (On-grid)</h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed mb-3 lg:mb-4">
          Phù hợp nhà máy, kho xưởng, tòa nhà văn phòng. Bán điện dư lên lưới, tối ưu hóa chi phí điện
        </p>
        <ul class="text-xs lg:text-sm text-gray-500 space-y-1 lg:space-y-2">
          <li class="flex items-center"><span class="w-2 h-2 bg-yellow-500 rounded-full mr-2"></span>Công suất từ 10kWp – 5MWp+</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-yellow-500 rounded-full mr-2"></span>Tấm pin mono PERC hiệu suất cao</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-yellow-500 rounded-full mr-2"></span>Bảo hành tấm pin 25 năm</li>
        </ul>
      </div>

      <!-- 2 -->
      <div class="group relative bg-gradient-to-br from-green-50 to-emerald-50 rounded-2xl p-6 lg:p-8 border border-green-200 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 service-card">
        <div class="relative mb-4 lg:mb-6 overflow-hidden rounded-xl shadow-lg">
          <img
            src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&h=200&fit=crop&crop=center"
            alt="Inverter hybrid lưu trữ điện"
            class="w-full h-28 lg:h-32 object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
        </div>
        <div class="w-12 h-12 lg:w-16 lg:h-16 bg-green-500 rounded-xl flex items-center justify-center mb-4 lg:mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3 lg:mb-4">Hệ thống hybrid + lưu trữ</h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed mb-3 lg:mb-4">
          Kết hợp inverter hybrid và ắc quy lithium, đảm bảo điện liên tục 24/7 kể cả khi mất điện lưới
        </p>
        <ul class="text-xs lg:text-sm text-gray-500 space-y-1 lg:space-y-2">
          <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Inverter hybrid 3–100kW</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Pin lithium LiFePO4 an toàn</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>Chuyển đổi nguồn dưới 20ms</li>
        </ul>
      </div>

      <!-- 3 -->
      <div class="group relative bg-gradient-to-br from-blue-50 to-cyan-50 rounded-2xl p-6 lg:p-8 border border-blue-200 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 service-card">
        <div class="relative mb-4 lg:mb-6 overflow-hidden rounded-xl shadow-lg">
          <img
            src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=400&h=200&fit=crop&crop=center"
            alt="Tư vấn thiết kế hệ thống điện mặt trời"
            class="w-full h-28 lg:h-32 object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
        </div>
        <div class="w-12 h-12 lg:w-16 lg:h-16 bg-blue-500 rounded-xl flex items-center justify-center mb-4 lg:mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3 lg:mb-4">Khảo sát & thiết kế kỹ thuật</h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed mb-3 lg:mb-4">
          Đội kỹ sư khảo sát thực địa, tính toán công suất, mô phỏng sản lượng và lập hồ sơ thiết kế chi tiết
        </p>
        <ul class="text-xs lg:text-sm text-gray-500 space-y-1 lg:space-y-2">
          <li class="flex items-center"><span class="w-2 h-2 bg-blue-500 rounded-full mr-2"></span>Khảo sát mái & kết cấu</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-blue-500 rounded-full mr-2"></span>Mô phỏng sản lượng PVsyst</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-blue-500 rounded-full mr-2"></span>Hồ sơ xin phép đấu nối lưới</li>
        </ul>
      </div>

      <!-- 4 -->
      <div class="group relative bg-gradient-to-br from-orange-50 to-red-50 rounded-2xl p-6 lg:p-8 border border-orange-200 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 service-card">
        <div class="relative mb-4 lg:mb-6 overflow-hidden rounded-xl shadow-lg">
          <img
            src="https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=400&h=200&fit=crop&crop=center"
            alt="Thi công lắp đặt điện mặt trời"
            class="w-full h-28 lg:h-32 object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
        </div>
        <div class="w-12 h-12 lg:w-16 lg:h-16 bg-orange-500 rounded-xl flex items-center justify-center mb-4 lg:mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3 lg:mb-4">Thi công & lắp đặt chuyên nghiệp</h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed mb-3 lg:mb-4">
          Đội thi công có kinh nghiệm, đảm bảo tiến độ, an toàn lao động và chất lượng theo tiêu chuẩn IEC
        </p>
        <ul class="text-xs lg:text-sm text-gray-500 space-y-1 lg:space-y-2">
          <li class="flex items-center"><span class="w-2 h-2 bg-orange-500 rounded-full mr-2"></span>Thi công đúng tiến độ cam kết</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-orange-500 rounded-full mr-2"></span>Nghiệm thu & bàn giao đầy đủ</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-orange-500 rounded-full mr-2"></span>Đấu nối lưới điện quốc gia</li>
        </ul>
      </div>

      <!-- 5 -->
      <div class="group relative bg-gradient-to-br from-teal-50 to-cyan-50 rounded-2xl p-6 lg:p-8 border border-teal-200 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 service-card">
        <div class="relative mb-4 lg:mb-6 overflow-hidden rounded-xl shadow-lg">
          <img
            src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=400&h=200&fit=crop&crop=center"
            alt="Giám sát hệ thống điện mặt trời từ xa"
            class="w-full h-28 lg:h-32 object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
        </div>
        <div class="w-12 h-12 lg:w-16 lg:h-16 bg-teal-500 rounded-xl flex items-center justify-center mb-4 lg:mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3 lg:mb-4">Giám sát & vận hành từ xa</h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed mb-3 lg:mb-4">
          Hệ thống SCADA/IoT theo dõi sản lượng, hiệu suất và cảnh báo sự cố theo thời gian thực
        </p>
        <ul class="text-xs lg:text-sm text-gray-500 space-y-1 lg:space-y-2">
          <li class="flex items-center"><span class="w-2 h-2 bg-teal-500 rounded-full mr-2"></span>Dashboard theo dõi 24/7</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-teal-500 rounded-full mr-2"></span>Báo cáo sản lượng tự động</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-teal-500 rounded-full mr-2"></span>Cảnh báo sự cố qua app/SMS</li>
        </ul>
      </div>

      <!-- 6 -->
      <div class="group relative bg-gradient-to-br from-indigo-50 to-purple-50 rounded-2xl p-6 lg:p-8 border border-indigo-200 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 service-card">
        <div class="relative mb-4 lg:mb-6 overflow-hidden rounded-xl shadow-lg">
          <img
            src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=400&h=200&fit=crop&crop=center"
            alt="Bảo trì bảo dưỡng hệ thống điện mặt trời"
            class="w-full h-28 lg:h-32 object-cover group-hover:scale-105 transition-transform duration-300"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
        </div>
        <div class="w-12 h-12 lg:w-16 lg:h-16 bg-indigo-500 rounded-xl flex items-center justify-center mb-4 lg:mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-6 h-6 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
          </svg>
        </div>
        <h3 class="text-lg lg:text-xl font-semibold text-gray-900 mb-3 lg:mb-4">Bảo trì & bảo hành dài hạn</h3>
        <p class="text-sm lg:text-base text-gray-600 leading-relaxed mb-3 lg:mb-4">
          Gói O&M (Operation & Maintenance) định kỳ, đảm bảo hệ thống luôn hoạt động ở hiệu suất tối ưu
        </p>
        <ul class="text-xs lg:text-sm text-gray-500 space-y-1 lg:space-y-2">
          <li class="flex items-center"><span class="w-2 h-2 bg-indigo-500 rounded-full mr-2"></span>Bảo trì định kỳ 2 lần/năm</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-indigo-500 rounded-full mr-2"></span>Bảo hành inverter 5–10 năm</li>
          <li class="flex items-center"><span class="w-2 h-2 bg-indigo-500 rounded-full mr-2"></span>Hỗ trợ kỹ thuật 24/7</li>
        </ul>
      </div>
    </div>

    <!-- Process -->
    <div class="mt-16 lg:mt-20">
      <div class="text-center mb-10 lg:mb-12">
        <h3 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">Quy trình triển khai dự án</h3>
        <p class="text-base sm:text-lg text-gray-600 max-w-2xl mx-auto">
          Quy trình chuẩn hóa, minh bạch từ khảo sát đến vận hành
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 lg:gap-8">
        {[
          { step: '1', color: 'from-yellow-500 to-orange-500', title: 'Khảo sát miễn phí', desc: 'Khảo sát mái, đo bức xạ, phân tích hóa đơn điện' },
          { step: '2', color: 'from-green-500 to-emerald-500', title: 'Thiết kế & báo giá', desc: 'Thiết kế kỹ thuật, mô phỏng sản lượng, báo giá chi tiết' },
          { step: '3', color: 'from-blue-500 to-cyan-500', title: 'Thi công & lắp đặt', desc: 'Thi công đúng tiến độ, đấu nối lưới, nghiệm thu' },
          { step: '4', color: 'from-purple-500 to-indigo-500', title: 'Vận hành & bảo trì', desc: 'Bàn giao, đào tạo vận hành, giám sát từ xa' },
        ].map(item => (
          <div class="text-center process-step">
            <div class="relative mb-6">
              <div class={`w-16 h-16 lg:w-20 lg:h-20 bg-gradient-to-r ${item.color} rounded-full flex items-center justify-center mx-auto shadow-lg`}>
                <span class="text-lg lg:text-xl font-bold text-white">{item.step}</span>
              </div>
              <div class="absolute -top-2 -right-2 w-6 h-6 bg-green-500 rounded-full flex items-center justify-center">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
            </div>
            <h4 class="text-base lg:text-lg font-semibold text-gray-900 mb-2">{item.title}</h4>
            <p class="text-sm lg:text-base text-gray-600">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-16 lg:mt-20 text-center">
      <div class="bg-gradient-to-r from-yellow-50 to-orange-50 rounded-2xl lg:rounded-3xl p-8 lg:p-12 border border-yellow-200">
        <h3 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">Bắt đầu dự án điện mặt trời ngay hôm nay</h3>
        <p class="text-base sm:text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
          Liên hệ để được khảo sát miễn phí và nhận báo giá chi tiết trong 24 giờ
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#quote-form" class="inline-flex items-center justify-center px-6 lg:px-8 py-3 lg:py-4 bg-gradient-to-r from-yellow-500 to-orange-500 text-white font-semibold rounded-xl hover:from-yellow-600 hover:to-orange-600 transition-all duration-300 transform hover:scale-105 shadow-lg">
            <span class="mr-2">Nhận báo giá</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a href={`tel:${COMPANY_INFO.hotline}`} class="inline-flex items-center justify-center px-6 lg:px-8 py-3 lg:py-4 border-2 border-yellow-500 text-yellow-600 font-semibold rounded-xl hover:bg-yellow-50 transition-all duration-300 transform hover:scale-105">
            <span class="mr-2">Gọi ngay</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .service-card { opacity: 0; transition: opacity 0.5s ease-out, transform 0.5s ease-out; }
  .process-step { opacity: 0; transition: opacity 0.5s ease-out, transform 0.5s ease-out; }
  @media (max-width: 768px) { .service-card, .process-step { opacity: 1; } }
</style>

<script>
  const isMobile = window.innerWidth <= 768;
  if (!isMobile) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).style.opacity = '1';
          (entry.target as HTMLElement).style.transform = 'none';
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.service-card, .process-step').forEach(el => observer.observe(el));
  }
</script>
