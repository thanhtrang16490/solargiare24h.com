<style>
  /* Core animations */
  @keyframes fadeInUp {
    0% {
      opacity: 0;
      transform: translateY(30px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes slideInLeft {
    0% {
      opacity: 0;
      transform: translateX(-20px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }
  
  @keyframes simpleFadeIn {
    0% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }
  
  /* Base service card styles */
  .service-card {
    --parallax-y: 0px;
    --animation-delay: 0s;
    opacity: 0;
    transition: all 0.3s ease-out;
    will-change: transform, opacity;
    backface-visibility: hidden;
    transform: translateZ(0); /* Force hardware acceleration */
  }
  
  /* Desktop animations */
  @media (min-width: 769px) and (prefers-reduced-motion: no-preference) {
    .service-card.animate-in {
      opacity: 1;
      animation: fadeInUp 0.8s ease-out var(--animation-delay) forwards;
      transform: translateY(var(--parallax-y));
    }
    
    .process-step.animate-in {
      opacity: 1;
      animation: slideInLeft 0.8s ease-out var(--animation-delay) forwards;
    }
    
    /* Enhanced hover effects for desktop */
    .service-card:hover {
      transform: translateY(calc(var(--parallax-y) - 8px)) scale(1.02);
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }
  }
  
  /* Mobile and reduced motion fallbacks */
  @media (max-width: 768px), (prefers-reduced-motion: reduce) {
    .service-card,
    .process-step {
      opacity: 1; /* Show immediately on mobile */
      transform: none;
      animation: none;
    }
    
    .service-card.simple-fade-in,
    .process-step.simple-fade-in {
      animation: simpleFadeIn 0.5s ease-out forwards;
    }
    
    /* Simplified mobile hover effects */
    .service-card:active {
      transform: scale(0.98);
      transition: transform 0.1s ease-out;
    }
  }
  
  /* Base process step styles */
  .process-step {
    opacity: 0;
    transition: all 0.3s ease-out;
  }
  
  /* Mobile-specific optimizations */
  @media (max-width: 640px) {
    .service-card {
      margin-bottom: 1rem;
      padding: 1rem !important; /* Override lg:p-8 for mobile */
    }
    
    /* Reduce motion intensity on mobile */
    .service-card img {
      transition: transform 0.2s ease-out;
    }
    
    .service-card:hover img {
      transform: scale(1.02); /* Reduced scale on mobile */
    }
  }
  
  /* Performance optimizations */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
  
  /* Touch device optimizations */
  @media (hover: none) and (pointer: coarse) {
    .service-card {
      transform: none !important;
    }
    
    .service-card:hover {
      transform: none !important;
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    }
    
    /* Disable parallax entirely on touch devices */
    .service-card.animate-in {
      transform: none !important;
    }
  }
  
  /* Grid improvements for better mobile layout */
  @media (max-width: 640px) {
    .grid.grid-cols-1.sm\\:grid-cols-2.lg\\:grid-cols-3 {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
  
  @media (min-width: 641px) and (max-width: 1023px) {
    .grid.grid-cols-1.sm\\:grid-cols-2.lg\\:grid-cols-3 {
      gap: 1.5rem;
    }
  }
</style>

<script>
  // Check if device supports smooth animations
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.innerWidth <= 768;
  
  // Declare observer in outer scope for cleanup
  let globalObserver;
  let scrollTimeout;
  
  if (!prefersReducedMotion && !isMobile) {
    // Enhanced Intersection Observer for animations - Desktop only
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -30px 0px'
    };
    
    globalObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-in');
        }
      });
    }, observerOptions);
    
    // Observe service cards with staggered animation
    document.querySelectorAll('.service-card').forEach((card, index) => {
      const htmlCard = card;
      htmlCard.style.setProperty('--animation-delay', `${index * 0.1}s`);
      globalObserver.observe(card);
    });
    
    // Observe process steps
    document.querySelectorAll('.process-step').forEach((step, index) => {
      const htmlStep = step;
      htmlStep.style.setProperty('--animation-delay', `${index * 0.15}s`);
      globalObserver.observe(step);
    });
    
    // Lightweight parallax effect - Desktop only
    let ticking = false;
    
    function updateParallax() {
      const scrolled = window.pageYOffset;
      const serviceCards = document.querySelectorAll('.service-card.animate-in');
      
      serviceCards.forEach((card, index) => {
        const rect = card.getBoundingClientRect();
        const isVisible = rect.top < window.innerHeight && rect.bottom > 0;
        
        if (isVisible) {
          const speed = 0.02 + (index * 0.005); // Reduced parallax intensity
          const yPos = scrolled * speed;
          const htmlCard = card;
          htmlCard.style.setProperty('--parallax-y', `${yPos}px`);
        }
      });
      
      ticking = false;
    }
    
    function requestParallax() {
      if (!ticking && !document.hidden) {
        requestAnimationFrame(updateParallax);
        ticking = true;
      }
    }
    
    // Throttled scroll listener
    window.addEventListener('scroll', () => {
      if (scrollTimeout) {
        clearTimeout(scrollTimeout);
      }
      scrollTimeout = setTimeout(requestParallax, 16); // ~60fps
    }, { passive: true });
  } else {
    // Simple fade-in for mobile and reduced motion
    globalObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('simple-fade-in');
        }
      });
    }, { threshold: 0.2 });
    
    document.querySelectorAll('.service-card, .process-step').forEach(element => {
      globalObserver.observe(element);
    });
  }
  
  // Cleanup on page unload
  window.addEventListener('beforeunload', () => {
    if (globalObserver) {
      globalObserver.disconnect();
    }
    if (scrollTimeout) {
      clearTimeout(scrollTimeout);
    }
  });
</script> 