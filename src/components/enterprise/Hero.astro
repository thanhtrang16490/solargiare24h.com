---
// Hero section for enterprise solar landing page
---

<section class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-blue-950 to-gray-900 min-h-screen flex items-center">
  <div class="absolute inset-0 bg-black/30"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/30 to-transparent"></div>

  <!-- Animated blobs -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-yellow-400/10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-blue-400/10 rounded-full blur-3xl animate-pulse animation-delay-2"></div>
  </div>

  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1509391366360-2e959784a276?w=1920&h=1080&fit=crop&crop=center"
      alt="Hệ thống điện mặt trời công nghiệp quy mô lớn"
      class="w-full h-full object-cover opacity-50 parallax-bg"
    />
  </div>

  <!-- Content -->
  <div class="relative z-20 container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <!-- Left -->
      <div class="text-center lg:text-left fade-in-up">
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-yellow-500/20 text-yellow-300 text-sm font-medium mb-6 backdrop-blur-sm border border-yellow-400/30">
          <span class="w-2 h-2 bg-yellow-400 rounded-full mr-2 animate-pulse"></span>
          Giải pháp năng lượng mặt trời cho doanh nghiệp
        </div>

        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 lg:mb-6 leading-tight">
          Hệ thống điện mặt trời
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-400 to-orange-400 animate-gradient">
            quy mô lớn
          </span>
          <br class="hidden sm:block">
          cho doanh nghiệp
        </h1>

        <p class="text-base sm:text-lg lg:text-xl text-gray-300 mb-6 lg:mb-8 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
          Tiết kiệm 70–90% chi phí điện, chủ động nguồn năng lượng 24/7. Thiết kế — thi công — vận hành trọn gói từ 10kWp đến 5MWp+
        </p>

        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center lg:justify-start">
          <a
            href="#quote-form"
            class="group inline-flex items-center justify-center px-6 sm:px-8 py-3 sm:py-4 rounded-xl bg-gradient-to-r from-yellow-500 to-orange-500 text-white font-semibold text-base sm:text-lg shadow-lg hover:from-yellow-600 hover:to-orange-600 transition-all duration-300 transform hover:scale-105"
          >
            <span class="mr-2">Nhận báo giá miễn phí</span>
            <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href="#services"
            class="group inline-flex items-center justify-center px-6 sm:px-8 py-3 sm:py-4 rounded-xl border-2 border-white/20 text-white font-semibold text-base sm:text-lg backdrop-blur-sm hover:bg-white/10 hover:border-white/30 transition-all duration-300 transform hover:scale-105"
          >
            <span class="mr-2">Xem dịch vụ</span>
            <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>

        <!-- Stats -->
        <div class="mt-8 lg:mt-12 grid grid-cols-2 sm:grid-cols-3 gap-4 lg:gap-8">
          <div class="text-center lg:text-left stats-item">
            <div class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-1">300+</div>
            <div class="text-sm sm:text-base text-gray-300">Dự án đã triển khai</div>
          </div>
          <div class="text-center lg:text-left stats-item">
            <div class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-1">50MWp+</div>
            <div class="text-sm sm:text-base text-gray-300">Tổng công suất lắp đặt</div>
          </div>
          <div class="text-center lg:text-left stats-item col-span-2 sm:col-span-1">
            <div class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-1">25 năm</div>
            <div class="text-sm sm:text-base text-gray-300">Tuổi thọ hệ thống</div>
          </div>
        </div>
      </div>

      <!-- Right card -->
      <div class="relative mt-8 lg:mt-0 fade-in-up animation-delay-2">
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-r from-yellow-500/20 to-orange-500/20 rounded-3xl blur-xl"></div>
          <div class="relative bg-white/10 backdrop-blur-xl rounded-3xl p-6 sm:p-8 border border-white/20 shadow-2xl">
            <div class="flex items-center mb-6">
              <div class="w-12 h-12 bg-gradient-to-r from-yellow-500 to-orange-500 rounded-xl flex items-center justify-center mr-4 shadow-lg">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-white">Tư vấn kỹ thuật chuyên sâu</h3>
                <p class="text-gray-300 text-sm">Miễn phí — Khảo sát tận nơi</p>
              </div>
            </div>
            <div class="space-y-4">
              <div class="flex items-center text-white">
                <svg class="w-5 h-5 text-yellow-400 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm sm:text-base">Khảo sát mái & tính toán công suất</span>
              </div>
              <div class="flex items-center text-white">
                <svg class="w-5 h-5 text-yellow-400 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm sm:text-base">Thiết kế hệ thống & mô phỏng sản lượng</span>
              </div>
              <div class="flex items-center text-white">
                <svg class="w-5 h-5 text-yellow-400 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm sm:text-base">Thi công — nghiệm thu — vận hành</span>
              </div>
              <div class="flex items-center text-white">
                <svg class="w-5 h-5 text-yellow-400 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm sm:text-base">Bảo trì định kỳ & giám sát từ xa</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating badges -->
        <div class="absolute -top-4 -right-4 bg-gradient-to-r from-yellow-500 to-orange-500 rounded-2xl p-4 shadow-xl floating-card">
          <div class="text-center">
            <div class="text-2xl font-bold text-white">90%</div>
            <div class="text-xs text-yellow-100">Tiết kiệm điện</div>
          </div>
        </div>
        <div class="absolute -bottom-4 -left-4 bg-gradient-to-r from-green-500 to-emerald-500 rounded-2xl p-4 shadow-xl floating-card animation-delay-2">
          <div class="text-center">
            <div class="text-2xl font-bold text-white">4–6 năm</div>
            <div class="text-xs text-green-100">Hoàn vốn</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 text-white animate-bounce">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>

<style>
  @keyframes gradient {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }
  @keyframes fadeInUp {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .animate-gradient { background-size: 200% 200%; animation: gradient 3s ease infinite; }
  .fade-in-up { animation: fadeInUp 0.6s ease-out; }
  .animation-delay-2 { animation-delay: 0.2s; }
  .floating-card { animation: float 3s ease-in-out infinite; }
  .stats-item { animation: fadeInUp 0.6s ease-out 0.8s both; }
  @media (max-width: 768px) { .floating-card { display: none; } }
  html { scroll-behavior: smooth; }
</style>

<script>
  window.addEventListener('scroll', () => {
    const scrolled = window.pageYOffset;
    const parallaxBg = document.querySelector('.parallax-bg') as HTMLElement | null;
    if (parallaxBg) parallaxBg.style.transform = `translateY(${scrolled * 0.4}px)`;
  });
</script>
