---
// Footer section for enterprise landing page
import { COMPANY_INFO } from '../../constants';
---

<footer class="bg-gray-900 text-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Company Info -->
        <div class="lg:col-span-2">
          <div class="flex items-center mb-6">
            <span class="text-xl font-bold">SOLAR24H</span>
          </div>
          <p class="text-gray-300 text-lg leading-relaxed mb-6">
            Chuyên cung cấp giải pháp thiết bị năng lượng mặt trời toàn diện cho doanh nghiệp. 
            Cam kết mang đến hệ thống điện mặt trời tối ưu nhất cho sự phát triển bền vững của tổ chức.
          </p>
          <div class="flex space-x-4">
            <a href="#" class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center hover:bg-blue-700 transition-colors duration-300">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"></path>
              </svg>
            </a>
            <a href="#" class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center hover:bg-blue-700 transition-colors duration-300">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.03c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"></path>
              </svg>
            </a>
            <a href="#" class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center hover:bg-blue-700 transition-colors duration-300">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
              </svg>
            </a>
          </div>
        </div>
        
        <!-- Quick Links -->
        <div>
          <h3 class="text-lg font-semibold mb-6">Liên kết nhanh</h3>
          <ul class="space-y-4">
            <li><a href="/san-pham" class="text-gray-300 hover:text-white transition-colors duration-300">Sản phẩm</a></li>
            <li><a href="/about" class="text-gray-300 hover:text-white transition-colors duration-300">Về chúng tôi</a></li>
            <li><a href="/faq-demo" class="text-gray-300 hover:text-white transition-colors duration-300">FAQ</a></li>
            <li><a href="/lien-he" class="text-gray-300 hover:text-white transition-colors duration-300">Liên hệ</a></li>
          </ul>
        </div>
        
        <!-- Policies -->
        <div>
          <h3 class="text-lg font-semibold mb-6">Chính sách</h3>
          <ul class="space-y-4">
            <li><a href="/noi-dung/chinh-sach-bao-hanh" class="text-gray-300 hover:text-white transition-colors duration-300">Chính sách bảo hành</a></li>
            <li><a href="/noi-dung/chinh-sach-doi-tra" class="text-gray-300 hover:text-white transition-colors duration-300">Chính sách đổi trả</a></li>
            <li><a href="/noi-dung/chinh-sach-bao-mat" class="text-gray-300 hover:text-white transition-colors duration-300">Chính sách bảo mật</a></li>
            <li><a href="/noi-dung/chinh-sach-giao-hang" class="text-gray-300 hover:text-white transition-colors duration-300">Chính sách giao hàng</a></li>
          </ul>
        </div>
      </div>
      
      <!-- Contact Info -->
      <div class="mt-12 pt-8 border-t border-gray-800">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="flex items-center">
            <div class="w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center mr-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
            </div>
            <div>
              <div class="text-sm text-gray-400">Hotline</div>
              <div class="text-lg font-semibold">
                <a href={`tel:${COMPANY_INFO.hotline}`} class="hover:text-blue-400 transition-colors">
                  {COMPANY_INFO.hotline}
                </a>
              </div>
            </div>
          </div>
          
          <div class="flex items-center">
            <div class="w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center mr-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div>
              <div class="text-sm text-gray-400">Email</div>
              <div class="text-lg font-semibold">
                <a href={`mailto:${COMPANY_INFO.email}`} class="hover:text-blue-400 transition-colors">
                  {COMPANY_INFO.email}
                </a>
              </div>
            </div>
          </div>
          
          <div class="flex items-center">
            <div class="w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center mr-4">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <div class="text-sm text-gray-400">Địa chỉ</div>
              <div class="text-sm font-semibold leading-relaxed">
                {COMPANY_INFO.address}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Bottom Bar -->
    <div class="border-t border-gray-800 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <div class="text-gray-400 text-sm mb-4 md:mb-0">
          © 2024 G3 Tech. Tất cả các quyền được bảo lưu.
        </div>
        <div class="flex items-center space-x-6">
          <div class="flex items-center">
            <img src="/images/bo-cong-thuong.png" alt="Bộ Công Thương" class="h-8 w-auto mr-2">
            <span class="text-xs text-gray-400">Đã đăng ký<br>Bộ Công Thương</span>
          </div>
          <div class="flex items-center">
            <img src="/images/dmca-badge.png" alt="DMCA Protected" class="h-8 w-auto mr-2">
            <span class="text-xs text-gray-400">DMCA<br>Protected</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer> 