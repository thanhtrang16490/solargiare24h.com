---
import ProductGallery from './ProductGallery';

export interface Props {
  productName: string;
  galleryUrl?: string;
  mainImageUrl?: string;
  galleryArray?: string[];
  videoInfo?: {
    videoUrl: string;
    thumbnail: string;
  };
  className?: string;
}

const { 
  productName, 
  galleryUrl, 
  mainImageUrl,
  galleryArray,
  videoInfo,
  className = "" 
} = Astro.props;

const filteredGalleryArray = galleryArray?.filter(
  (img) => img !== mainImageUrl
);
---

<ProductGallery 
  client:load
  productName={productName}
  galleryUrl={galleryUrl}
  mainImageUrl={mainImageUrl}
  galleryArray={filteredGalleryArray}
  videoInfo={videoInfo}
  className={className}
/> 