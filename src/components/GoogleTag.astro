---
// Google Tag (Google Ads) Configuration
const GOOGLE_TAG_ID = 'AW-17425925094';
---

<!-- Google tag (gtag.js) with Partytown for better performance -->
<script type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${GOOGLE_TAG_ID}`}></script>
<script type="text/partytown" is:inline define:vars={{ GOOGLE_TAG_ID }}>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', GOOGLE_TAG_ID);
</script>

<!-- Preconnect for better performance -->
<link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
<link rel="dns-prefetch" href="https://www.google-analytics.com">