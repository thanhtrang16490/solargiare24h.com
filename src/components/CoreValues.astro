---
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Giá trị
        <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
          cốt lõi
        </span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Bốn giá trị cốt lõi định hình nên ADN của SOLAR24H trong việc phục vụ 
        và mang lại giá trị tốt nhất cho khách hàng
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Value 1: Hiểu khách hàng -->
      <div class="group relative">
        <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-purple-600 rounded-3xl blur opacity-0 group-hover:opacity-25 transition duration-1000 group-hover:duration-200"></div>
        <div class="relative bg-white rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:scale-105 hover:-translate-y-2 border border-gray-100">
          <div class="text-center">
            <div class="w-20 h-20 bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Hiểu khách hàng</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Lắng nghe và thấu hiểu sâu sắc nhu cầu thực tế của từng khách hàng để đưa ra giải pháp phù hợp nhất
            </p>
            <div class="mt-4 flex justify-center">
              <div class="w-16 h-1 bg-gradient-to-r from-blue-600 to-purple-600 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Value 2: Giải pháp toàn diện -->
      <div class="group relative">
        <div class="absolute -inset-1 bg-gradient-to-r from-green-600 to-teal-600 rounded-3xl blur opacity-0 group-hover:opacity-25 transition duration-1000 group-hover:duration-200"></div>
        <div class="relative bg-white rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:scale-105 hover:-translate-y-2 border border-gray-100">
          <div class="text-center">
            <div class="w-20 h-20 bg-gradient-to-r from-green-600 to-teal-600 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Giải pháp toàn diện</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Cung cấp giải pháp hoàn chỉnh từ tư vấn, thiết kế, thi công đến hậu mãi cho hệ thống điện mặt trời
            </p>
            <div class="mt-4 flex justify-center">
              <div class="w-16 h-1 bg-gradient-to-r from-green-600 to-teal-600 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Value 3: Dịch vụ hậu mãi -->
      <div class="group relative">
        <div class="absolute -inset-1 bg-gradient-to-r from-purple-600 to-pink-600 rounded-3xl blur opacity-0 group-hover:opacity-25 transition duration-1000 group-hover:duration-200"></div>
        <div class="relative bg-white rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:scale-105 hover:-translate-y-2 border border-gray-100">
          <div class="text-center">
            <div class="w-20 h-20 bg-gradient-to-r from-purple-600 to-pink-600 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Dịch vụ hậu mãi</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Cam kết hỗ trợ và chăm sóc khách hàng tận tâm, đảm bảo sự hài lòng lâu dài
            </p>
            <div class="mt-4 flex justify-center">
              <div class="w-16 h-1 bg-gradient-to-r from-purple-600 to-pink-600 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Value 4: Sáng tạo công nghệ -->
      <div class="group relative">
        <div class="absolute -inset-1 bg-gradient-to-r from-yellow-600 to-orange-600 rounded-3xl blur opacity-0 group-hover:opacity-25 transition duration-1000 group-hover:duration-200"></div>
        <div class="relative bg-white rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:scale-105 hover:-translate-y-2 border border-gray-100">
          <div class="text-center">
            <div class="w-20 h-20 bg-gradient-to-r from-yellow-600 to-orange-600 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform duration-300 shadow-lg">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Sáng tạo công nghệ</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Đón đầu xu hướng, áp dụng công nghệ mới nhất để mang lại trải nghiệm vượt trội
            </p>
            <div class="mt-4 flex justify-center">
              <div class="w-16 h-1 bg-gradient-to-r from-yellow-600 to-orange-600 rounded-full"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Additional Benefits Section -->
    <div class="mt-20 bg-gradient-to-r from-blue-50 to-purple-50 rounded-3xl p-8 lg:p-12">
      <div class="text-center mb-12">
        <h3 class="text-3xl font-bold text-gray-900 mb-4">Tại sao chọn SOLAR24H?</h3>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Chúng tôi không chỉ cung cấp sản phẩm mà còn mang đến trải nghiệm làm việc tốt nhất
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="flex items-start space-x-4">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold text-gray-900 mb-2">Bảo hành chính hãng</h4>
            <p class="text-gray-600 text-sm">Tất cả sản phẩm được bảo hành theo tiêu chuẩn quốc tế</p>
          </div>
        </div>
        
        <div class="flex items-start space-x-4">
          <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold text-gray-900 mb-2">Thanh toán linh hoạt</h4>
            <p class="text-gray-600 text-sm">Hỗ trợ nhiều hình thức thanh toán, trả góp 0% lãi suất</p>
          </div>
        </div>
        
        <div class="flex items-start space-x-4">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold text-gray-900 mb-2">Giao hàng nhanh chóng</h4>
            <p class="text-gray-600 text-sm">Giao hàng toàn quốc trong vòng 24-48 giờ</p>
          </div>
        </div>
        
        <div class="flex items-start space-x-4">
          <div class="w-12 h-12 bg-yellow-100 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold text-gray-900 mb-2">Tư vấn chuyên sâu</h4>
            <p class="text-gray-600 text-sm">Đội ngũ chuyên gia giàu kinh nghiệm tư vấn 24/7</p>
          </div>
        </div>
        
        <div class="flex items-start space-x-4">
          <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold text-gray-900 mb-2">Chăm sóc tận tâm</h4>
            <p class="text-gray-600 text-sm">Dịch vụ hậu mãi chu đáo, hỗ trợ trọn đời</p>
          </div>
        </div>
        
        <div class="flex items-start space-x-4">
          <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
            </svg>
          </div>
          <div>
            <h4 class="font-semibold text-gray-900 mb-2">Chất lượng đảm bảo</h4>
            <p class="text-gray-600 text-sm">Sản phẩm được kiểm tra chất lượng nghiêm ngặt</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .card-hover-effect {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .card-hover-effect:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }
</style> 