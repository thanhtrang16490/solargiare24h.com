---
interface Props {
  specs: Record<string, string>;
}

const { specs } = Astro.props;

// Don't render if there are no specifications
if (Object.keys(specs).length === 0) {
  return null;
}
---

<div>
  <h2 class="text-2xl font-bold text-gray-900 mb-4">Thông số kỹ thuật</h2>
  <div class="border rounded-lg overflow-hidden">
    {Object.entries(specs).map(([key, value], index) => (
      <div class={`flex ${index !== 0 ? 'border-t' : ''}`}>
        <div class="w-1/3 bg-gray-50 p-4 font-medium text-gray-700">{key}</div>
        <div class="w-2/3 p-4 text-gray-600">{value}</div>
      </div>
    ))}
  </div>
</div> 