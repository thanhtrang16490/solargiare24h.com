---
---

<section class="py-20 bg-gradient-to-b from-white to-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
        Hành trình phát triển
        <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent block mt-2">
          SOLAR24H
        </span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Từ ý tưởng khởi nghiệp đến trở thành công ty dẫn đầu về giải pháp hệ thống điện mặt trời solar
      </p>
    </div>
    
    <div class="relative">
      <!-- Timeline Line -->
      <div class="absolute left-1/2 transform -translate-x-1/2 w-1 h-full bg-gradient-to-b from-blue-200 via-purple-200 to-green-200"></div>
      
      <div class="space-y-12">
        <!-- Q1 2024 - Khởi nghiệp -->
        <div class="relative flex items-center">
          <div class="flex-1 pr-8 text-right">
            <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100 hover:shadow-xl transition-shadow duration-300">
              <div class="flex items-center justify-end mb-4">
                <img 
                  src="https://images.unsplash.com/photo-1559136555-9303baea8ebd?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=200&q=80" 
                  alt="Startup idea"
                  class="w-16 h-16 rounded-xl object-cover"
                />
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Q1 2024 - Khởi nghiệp</h3>
              <p class="text-gray-600 mb-4">
                Thành lập SOLAR24H với tầm nhìn cách mạng hóa hệ thống điện mặt trời tại Việt Nam. 
                Đội ngũ sáng lập gồm 5 chuyên gia từ các lĩnh vực công nghệ, thiết kế và solar.
              </p>
              <div class="flex justify-end">
                <span class="inline-block px-3 py-1 bg-blue-100 text-blue-600 rounded-full text-sm font-medium">
                  Thành lập
                </span>
              </div>
            </div>
          </div>
          
          <div class="absolute left-1/2 transform -translate-x-1/2 w-12 h-12 bg-gradient-to-r from-blue-600 to-purple-600 rounded-full flex items-center justify-center z-10">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          
          <div class="flex-1 pl-8"></div>
        </div>
        
        <!-- Q2 2024 - Sản phẩm đầu tiên -->
        <div class="relative flex items-center">
          <div class="flex-1 pr-8"></div>
          
          <div class="absolute left-1/2 transform -translate-x-1/2 w-12 h-12 bg-gradient-to-r from-purple-600 to-pink-600 rounded-full flex items-center justify-center z-10">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
            </svg>
          </div>
          
          <div class="flex-1 pl-8">
            <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100 hover:shadow-xl transition-shadow duration-300">
              <div class="flex items-center mb-4">
                <img 
                  src="https://images.unsplash.com/photo-1581539250439-c96689b516dd?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=200&q=80" 
                  alt="First product"
                  class="w-16 h-16 rounded-xl object-cover"
                />
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Q2 2024 - Sản phẩm đầu tiên</h3>
              <p class="text-gray-600 mb-4">
                Ra mắt dòng inverter hòa lưới G3-Series với công nghệ 3D fitting. 
                Thiết kế dựa trên dữ liệu nghiên cứu về cơ thể người Việt Nam.
              </p>
              <div class="flex">
                <span class="inline-block px-3 py-1 bg-purple-100 text-purple-600 rounded-full text-sm font-medium">
                  Sản phẩm
                </span>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Q3 2024 - Mở rộng thị trường -->
        <div class="relative flex items-center">
          <div class="flex-1 pr-8 text-right">
            <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100 hover:shadow-xl transition-shadow duration-300">
              <div class="flex items-center justify-end mb-4">
                <img 
                  src="https://images.unsplash.com/photo-1556155092-490a1ba16284?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=200&q=80" 
                  alt="Market expansion"
                  class="w-16 h-16 rounded-xl object-cover"
                />
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Q3 2024 - Mở rộng thị trường</h3>
              <p class="text-gray-600 mb-4">
                Hợp tác với 50+ doanh nghiệp lớn tại Hà Nội và TP.HCM. 
                Khai trương showroom đầu tiên tại trung tâm thành phố.
              </p>
              <div class="flex justify-end">
                <span class="inline-block px-3 py-1 bg-green-100 text-green-600 rounded-full text-sm font-medium">
                  Mở rộng
                </span>
              </div>
            </div>
          </div>
          
          <div class="absolute left-1/2 transform -translate-x-1/2 w-12 h-12 bg-gradient-to-r from-green-600 to-teal-600 rounded-full flex items-center justify-center z-10">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
            </svg>
          </div>
          
          <div class="flex-1 pl-8"></div>
        </div>
        
        <!-- Q4 2024 - Công nghệ AI -->
        <div class="relative flex items-center">
          <div class="flex-1 pr-8"></div>
          
          <div class="absolute left-1/2 transform -translate-x-1/2 w-12 h-12 bg-gradient-to-r from-orange-600 to-red-600 rounded-full flex items-center justify-center z-10">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path>
            </svg>
          </div>
          
          <div class="flex-1 pl-8">
            <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100 hover:shadow-xl transition-shadow duration-300">
              <div class="flex items-center mb-4">
                <img 
                  src="https://images.unsplash.com/photo-1485827404703-89b55fcc595e?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=200&q=80" 
                  alt="AI Technology"
                  class="w-16 h-16 rounded-xl object-cover"
                />
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Q4 2024 - Công nghệ AI</h3>
              <p class="text-gray-600 mb-4">
                Phát triển hệ thống AI G3-Smart để tư vấn thiết kế tự động. 
                Tích hợp VR/AR cho trải nghiệm khách hàng immersive.
              </p>
              <div class="flex">
                <span class="inline-block px-3 py-1 bg-orange-100 text-orange-600 rounded-full text-sm font-medium">
                  Công nghệ
                </span>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Q1 2025 - Quốc tế hóa -->
        <div class="relative flex items-center">
          <div class="flex-1 pr-8 text-right">
            <div class="bg-white rounded-2xl p-6 shadow-lg border border-gray-100 hover:shadow-xl transition-shadow duration-300">
              <div class="flex items-center justify-end mb-4">
                <img 
                  src="https://images.unsplash.com/photo-1557804506-669a67965ba0?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=200&q=80" 
                  alt="Global expansion"
                  class="w-16 h-16 rounded-xl object-cover"
                />
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Q1 2025 - Quốc tế hóa</h3>
              <p class="text-gray-600 mb-4">
                Kế hoạch mở rộng ra thị trường Đông Nam Á. 
                Hợp tác với các đối tác quốc tế để phân phối sản phẩm.
              </p>
              <div class="flex justify-end">
                <span class="inline-block px-3 py-1 bg-indigo-100 text-indigo-600 rounded-full text-sm font-medium">
                  Tương lai
                </span>
              </div>
            </div>
          </div>
          
          <div class="absolute left-1/2 transform -translate-x-1/2 w-12 h-12 bg-gradient-to-r from-indigo-600 to-purple-600 rounded-full flex items-center justify-center z-10">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          
          <div class="flex-1 pl-8"></div>
        </div>
      </div>
    </div>
    
    <!-- Achievements Section -->
    <div class="mt-20">
      <div class="bg-gradient-to-r from-blue-50 to-purple-50 rounded-3xl p-8 md:p-12">
        <div class="text-center mb-12">
          <h3 class="text-3xl font-bold text-gray-900 mb-4">
            Thành tựu đáng tự hào
          </h3>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto">
            Những cột mốc quan trọng đánh dấu sự phát triển vượt bậc của SOLAR24H
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="w-20 h-20 bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <img 
                src="https://images.unsplash.com/photo-1553729459-efe14ef6055d?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=60&q=80" 
                alt="Award icon"
                class="w-10 h-10 object-cover rounded-lg"
              />
            </div>
            <h4 class="text-xl font-bold text-gray-900 mb-2">Giải thưởng</h4>
            <p class="text-3xl font-bold text-blue-600 mb-2">5+</p>
            <p class="text-gray-600">Giải thưởng thiết kế quốc tế</p>
          </div>
          
          <div class="text-center">
            <div class="w-20 h-20 bg-gradient-to-r from-green-600 to-teal-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <img 
                src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=60&q=80" 
                alt="Client satisfaction"
                class="w-10 h-10 object-cover rounded-lg"
              />
            </div>
            <h4 class="text-xl font-bold text-gray-900 mb-2">Khách hàng</h4>
            <p class="text-3xl font-bold text-green-600 mb-2">500+</p>
            <p class="text-gray-600">Doanh nghiệp tin tưởng</p>
          </div>
          
          <div class="text-center">
            <div class="w-20 h-20 bg-gradient-to-r from-orange-600 to-red-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <img 
                src="https://images.unsplash.com/photo-1560472354-b33ff0c44a43?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=60&q=80" 
                alt="Products delivered"
                class="w-10 h-10 object-cover rounded-lg"
              />
            </div>
            <h4 class="text-xl font-bold text-gray-900 mb-2">Sản phẩm</h4>
            <p class="text-3xl font-bold text-orange-600 mb-2">5000+</p>
            <p class="text-gray-600">Đã được lắp đặt</p>
          </div>
          
          <div class="text-center">
            <div class="w-20 h-20 bg-gradient-to-r from-purple-600 to-pink-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <img 
                src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=60&q=80" 
                alt="Market presence"
                class="w-10 h-10 object-cover rounded-lg"
              />
            </div>
            <h4 class="text-xl font-bold text-gray-900 mb-2">Thị trường</h4>
            <p class="text-3xl font-bold text-purple-600 mb-2">3</p>
            <p class="text-gray-600">Thành phố lớn</p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Vision 2025+ -->
    <div class="mt-16 text-center">
      <div class="bg-gradient-to-r from-gray-900 to-blue-900 rounded-3xl p-8 md:p-12 text-white">
        <h3 class="text-3xl md:text-4xl font-bold mb-6">
          Tầm nhìn 2025+
        </h3>
        <p class="text-xl text-gray-300 mb-8 max-w-4xl mx-auto">
          Trở thành công ty dẫn đầu Đông Nam Á về giải pháp hệ thống điện mặt trời thông minh, 
          góp phần nâng cao chất lượng cuộc sống làm việc cho hàng triệu người.
        </p>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
          <div>
            <div class="text-3xl font-bold text-cyan-400 mb-2">10+</div>
            <div class="text-gray-300">Quốc gia có mặt</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-blue-400 mb-2">1M+</div>
            <div class="text-gray-300">Người dùng hàng ngày</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-purple-400 mb-2">50%</div>
            <div class="text-gray-300">Thị phần khu vực</div>
          </div>
        </div>
        
        <button class="bg-gradient-to-r from-cyan-600 to-blue-600 text-white px-8 py-4 rounded-2xl font-bold hover:scale-105 transition-transform duration-300">
          Đồng hành cùng SOLAR24H
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .timeline-item {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s ease-in-out;
  }
  
  .timeline-item.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Intersection Observer for timeline animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  });

  // Observe all timeline items
  document.querySelectorAll('.timeline-item').forEach((item) => {
    observer.observe(item);
  });
</script> 