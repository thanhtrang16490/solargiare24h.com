---
export interface FAQItem {
  question: string;
  answer: string;
}

export interface Props {
  title?: string;
  items?: FAQItem[];
  className?: string;
}

const { 
  title = "Câu hỏi thường gặp", 
  items = [
    {
      question: "Thiết bị điện mặt trời phù hợp cho đối tượng nào?",
      answer: "Thiết bị phù hợp cho hộ gia đình, doanh nghiệp, trang trại và bất kỳ ai muốn tiết kiệm điện."
    },
    {
      question: "Bảo hành sản phẩm trong bao lâu?",
      answer: "Sản phẩm được bảo hành 12 tháng cho phần cơ khí và 6 tháng cho lưới."
    },
    {
      question: "Có miễn phí lắp đặt không?",
      answer: "SOLAR24H miễn phí lắp đặt tại Hà Nội và TP. Hồ Chí Minh."
    },
    {
      question: "Sản phẩm có thể tùy chỉnh như thế nào?",
      answer: "Sản phẩm có thể điều chỉnh chiều cao, tựa đầu, tựa lưng, các tay và góc ngả giúp phù hợp với mọi tư thế và nhu cầu sử dụng."
    },
    {
      question: "Chất liệu lưới có bị bám bụi không?",
      answer: "Chất liệu lưới Solidmesh USA có khả năng chống bám bụi tốt và dễ dàng vệ sinh bằng khăn ẩm."
    }
  ],
  className = "" 
} = Astro.props;
---

<div class={`mt-12 ${className}`}>
  <h2 class="text-2xl font-bold mb-4">{title}</h2>
  
  <div class="space-y-4">
    {items.map((faq, index) => (
      <div class="faq-item overflow-hidden rounded-lg border border-gray-200 bg-white">
        <button
          class="faq-trigger group flex w-full items-center justify-between px-4 py-3 text-left font-medium text-gray-900 hover:bg-gray-50 transition-colors"
          data-index={index}
        >
          <span>{faq.question}</span>
          <svg
            class="faq-icon h-5 w-5 text-gray-500 transform transition-transform duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"
            ></path>
          </svg>
        </button>
        <div
          class="faq-content overflow-hidden transition-all duration-300 max-h-0 opacity-0"
          data-index={index}
        >
          <div class="px-4 py-3 text-gray-700">
            {faq.answer}
          </div>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .faq-item {
    transition: all 0.3s ease;
  }
  
  .faq-trigger:focus {
    outline: none;
    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.1);
  }
  
  .faq-content {
    border-top: 1px solid #f3f4f6;
  }
  
  .faq-content.open {
    max-height: 500px;
    opacity: 1;
  }
  
  .faq-icon.rotate {
    transform: rotate(180deg);
  }
</style>

<script>
  // FAQ functionality matching NextJS behavior
  document.addEventListener('DOMContentLoaded', function() {
    const faqTriggers = document.querySelectorAll('.faq-trigger');
    let openItem = null;
    
    faqTriggers.forEach(function(trigger) {
      trigger.addEventListener('click', function() {
        const index = trigger.getAttribute('data-index');
        const content = document.querySelector('.faq-content[data-index="' + index + '"]');
        const icon = trigger.querySelector('.faq-icon');
        
        if (!content || !icon) return;
        
        const isOpen = content.classList.contains('open');
        
        // Close all other items (single accordion behavior)
        document.querySelectorAll('.faq-content').forEach(function(item) {
          item.classList.remove('open');
        });
        
        document.querySelectorAll('.faq-icon').forEach(function(ic) {
          ic.classList.remove('rotate');
        });
        
        // Toggle current item
        if (!isOpen) {
          content.classList.add('open');
          icon.classList.add('rotate');
          openItem = index;
        } else {
          content.classList.remove('open');
          icon.classList.remove('rotate');
          openItem = null;
        }
      });
    });
  });
</script> 