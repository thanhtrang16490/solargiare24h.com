---
---

<section class="py-20 bg-gradient-to-b from-gray-50 to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
        Cam kết
        <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
          Chất lượng & Dịch vụ
        </span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Chúng tôi cam kết mang đến những sản phẩm thiết bị điện mặt trời chất lượng cao và dịch vụ tốt nhất
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Chất lượng sản phẩm -->
      <div class="group bg-white rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
        <div class="relative mb-6">
          <div class="w-32 h-32 mx-auto rounded-full overflow-hidden bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center">
            <svg class="w-16 h-16 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div class="absolute -bottom-2 -right-2 w-8 h-8 bg-gradient-to-r from-blue-600 to-purple-600 rounded-full flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
        </div>
        <div class="text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Chất lượng vượt trội</h3>
          <p class="text-blue-600 font-semibold mb-3">Sản phẩm cao cấp</p>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">
            Chúng tôi cam kết cung cấp các sản phẩm thiết bị điện mặt trời chất lượng cao, 
            được nhập khẩu từ những thương hiệu uy tín hàng đầu thế giới.
          </p>
        </div>
      </div>
      
      <!-- Dịch vụ tư vấn -->
      <div class="group bg-white rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
        <div class="relative mb-6">
          <div class="w-32 h-32 mx-auto rounded-full overflow-hidden bg-gradient-to-br from-green-500 to-teal-600 flex items-center justify-center">
            <svg class="w-16 h-16 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
          </div>
          <div class="absolute -bottom-2 -right-2 w-8 h-8 bg-gradient-to-r from-green-600 to-teal-600 rounded-full flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2h2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          </div>
        </div>
        <div class="text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Tư vấn chuyên nghiệp</h3>
          <p class="text-green-600 font-semibold mb-3">Hỗ trợ 24/7</p>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">
            Đội ngũ tư vấn giàu kinh nghiệm, hiểu biết sâu về solar và nhu cầu 
            sử dụng để tư vấn sản phẩm phù hợp nhất.
          </p>
        </div>
      </div>
      
      <!-- Giao hàng nhanh -->
      <div class="group bg-white rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
        <div class="relative mb-6">
          <div class="w-32 h-32 mx-auto rounded-full overflow-hidden bg-gradient-to-br from-orange-500 to-red-600 flex items-center justify-center">
            <svg class="w-16 h-16 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <div class="absolute -bottom-2 -right-2 w-8 h-8 bg-gradient-to-r from-orange-600 to-red-600 rounded-full flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
        </div>
        <div class="text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Giao hàng nhanh chóng</h3>
          <p class="text-orange-600 font-semibold mb-3">Toàn quốc</p>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">
            Hệ thống giao hàng toàn quốc với thời gian nhanh chóng, 
            đảm bảo sản phẩm đến tay khách hàng trong tình trạng tốt nhất.
          </p>
        </div>
      </div>
      
      <!-- Bảo hành -->
      <div class="group bg-white rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
        <div class="relative mb-6">
          <div class="w-32 h-32 mx-auto rounded-full overflow-hidden bg-gradient-to-br from-purple-500 to-pink-600 flex items-center justify-center">
            <svg class="w-16 h-16 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <div class="absolute -bottom-2 -right-2 w-8 h-8 bg-gradient-to-r from-purple-600 to-pink-600 rounded-full flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
          </div>
        </div>
        <div class="text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Bảo hành tin cậy</h3>
          <p class="text-purple-600 font-semibold mb-3">Chính sách rõ ràng</p>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">
            Chế độ bảo hành rõ ràng, minh bạch với dịch vụ hỗ trợ 
            sau bán hàng tận tâm và chuyên nghiệp.
          </p>
        </div>
      </div>
      
      <!-- Giá cả hợp lý -->
      <div class="group bg-white rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
        <div class="relative mb-6">
          <div class="w-32 h-32 mx-auto rounded-full overflow-hidden bg-gradient-to-br from-indigo-500 to-blue-600 flex items-center justify-center">
            <svg class="w-16 h-16 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div class="absolute -bottom-2 -right-2 w-8 h-8 bg-gradient-to-r from-indigo-600 to-blue-600 rounded-full flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
            </svg>
          </div>
        </div>
        <div class="text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Giá cả hợp lý</h3>
          <p class="text-indigo-600 font-semibold mb-3">Cạnh tranh thị trường</p>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">
            Mức giá hợp lý, cạnh tranh với nhiều chương trình khuyến mãi 
            và chính sách thanh toán linh hoạt.
          </p>
        </div>
      </div>
      
      <!-- Đa dạng sản phẩm -->
      <div class="group bg-white rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
        <div class="relative mb-6">
          <div class="w-32 h-32 mx-auto rounded-full overflow-hidden bg-gradient-to-br from-teal-500 to-cyan-600 flex items-center justify-center">
            <svg class="w-16 h-16 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
          </div>
          <div class="absolute -bottom-2 -right-2 w-8 h-8 bg-gradient-to-r from-teal-600 to-cyan-600 rounded-full flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
            </svg>
          </div>
        </div>
        <div class="text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Đa dạng sản phẩm</h3>
          <p class="text-teal-600 font-semibold mb-3">Phong phú lựa chọn</p>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">
            Hàng trăm sản phẩm từ các thương hiệu nổi tiếng, 
            đáp ứng mọi nhu cầu và ngân sách của khách hàng.
          </p>
        </div>
      </div>
    </div>
    
    <!-- Commitment Statistics -->
    <div class="mt-20 bg-gradient-to-r from-blue-50 to-purple-50 rounded-3xl p-12">
      <div class="text-center mb-12">
        <h3 class="text-3xl font-bold text-gray-900 mb-4">
          Thành tích & Cam kết
        </h3>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          Những con số chứng minh cho chất lượng dịch vụ và sự tin tưởng từ khách hàng
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h4 class="text-3xl font-bold text-gray-900 mb-2">10,000+</h4>
          <p class="text-gray-600">Khách hàng tin tưởng</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-r from-green-600 to-teal-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h4 class="text-3xl font-bold text-gray-900 mb-2">98%</h4>
          <p class="text-gray-600">Khách hàng hài lòng</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-r from-orange-600 to-red-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
          </div>
          <h4 class="text-3xl font-bold text-gray-900 mb-2">500+</h4>
          <p class="text-gray-600">Sản phẩm đa dạng</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-gradient-to-r from-purple-600 to-pink-600 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h4 class="text-3xl font-bold text-gray-900 mb-2">24/7</h4>
          <p class="text-gray-600">Hỗ trợ khách hàng</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
  }
</style> 