---
import { COMPANY_INFO } from '../constants';
---

<section class="relative py-20 bg-gradient-to-br from-gray-900 via-blue-900 to-purple-900 text-white overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <img 
      src="https://images.unsplash.com/photo-1508514177221-188b1cf16e9d?w=2000&q=80" 
      alt="Hệ thống điện mặt trời"
      class="w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-gray-900/80 via-blue-900/80 to-purple-900/80"></div>
  </div>
  
  <!-- 3D Floating Elements -->
  <div class="absolute inset-0">
    <div class="absolute top-20 left-20 w-32 h-32 bg-blue-400/10 rounded-full blur-xl animate-pulse"></div>
    <div class="absolute bottom-20 right-20 w-40 h-40 bg-purple-400/10 rounded-full blur-xl animate-pulse delay-1000"></div>
    <div class="absolute top-1/2 left-1/4 w-24 h-24 bg-cyan-400/10 rounded-full blur-xl animate-pulse delay-500"></div>
  </div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-6xl font-bold mb-6 leading-tight">
        Sẵn sàng tạo ra
        <span class="bg-gradient-to-r from-cyan-400 via-blue-500 to-purple-600 bg-clip-text text-transparent block mt-2">
          hệ thống điện mặt trời tương lai?
        </span>
      </h2>
      <p class="text-xl md:text-2xl text-gray-300 max-w-4xl mx-auto leading-relaxed">
        Hãy để SOLAR24H đồng hành cùng bạn trong hành trình biến đổi số hệ thống điện mặt trời. 
        Từ ý tưởng đến hiện thực, chúng tôi cam kết mang đến trải nghiệm làm việc tuyệt vời nhất.
      </p>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left: Contact Info -->
      <div class="space-y-8">
        <div class="bg-white/10 backdrop-blur-sm rounded-3xl p-8 border border-white/20">
          <h3 class="text-2xl font-bold mb-6 text-white">
            Liên hệ tư vấn miễn phí
          </h3>
          
          <div class="space-y-6">
            <div class="flex items-center space-x-4">
              <div class="w-12 h-12 bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
              </div>
              <div>
                <p class="text-gray-300 text-sm">Hotline</p>
                <p class="text-white text-lg font-semibold">
                  <a href={`tel:${COMPANY_INFO.hotline}`} class="hover:text-blue-400 transition-colors">
                    {COMPANY_INFO.hotline}
                  </a>
                </p>
              </div>
            </div>
            
            <div class="flex items-center space-x-4">
              <div class="w-12 h-12 bg-gradient-to-r from-green-600 to-teal-600 rounded-2xl flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <p class="text-gray-300 text-sm">Email</p>
                <p class="text-white text-lg font-semibold">
                  <a href={`mailto:${COMPANY_INFO.email}`} class="hover:text-green-400 transition-colors">
                    {COMPANY_INFO.email}
                  </a>
                </p>
              </div>
            </div>
            
            <div class="flex items-center space-x-4">
              <div class="w-12 h-12 bg-gradient-to-r from-orange-600 to-red-600 rounded-2xl flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <p class="text-gray-300 text-sm">Địa chỉ</p>
                <p class="text-white text-lg font-semibold">{COMPANY_INFO.address}</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Social Media -->
        <div class="bg-white/10 backdrop-blur-sm rounded-3xl p-6 border border-white/20">
          <h4 class="text-lg font-semibold mb-4 text-white">
            Kết nối với chúng tôi
          </h4>
          <div class="flex space-x-4">
            <a href="https://www.facebook.com/g3.vntech/" target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-blue-600 rounded-2xl flex items-center justify-center hover:bg-blue-700 transition-colors">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a href="https://www.tiktok.com/@solar24h.vn" target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-gray-900 rounded-2xl flex items-center justify-center hover:bg-gray-800 transition-colors">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
              </svg>
            </a>
            <a href="https://shopee.vn/solar24h" target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-orange-600 rounded-2xl flex items-center justify-center hover:bg-orange-700 transition-colors">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0.75C5.785 0.75 0.75 5.785 0.75 12S5.785 23.25 12 23.25 23.25 18.215 23.25 12 18.215 0.75 12 0.75zm-1.666 18.5h-1.25v-6.25h1.25V19.25zm0-7.5h-1.25v-1.25h1.25v1.25zm5.833 7.5h-1.25v-3.125c0-1.25-1.042-2.5-2.5-2.5s-2.5 1.25-2.5 2.5v3.125h-1.25v-3.125c0-2.083 1.667-3.75 3.75-3.75s3.75 1.667 3.75 3.75v3.125z"/>
              </svg>
            </a>
            <a href="https://www.youtube.com/@g3-tech" target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-red-600 rounded-2xl flex items-center justify-center hover:bg-red-700 transition-colors">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
      
      <!-- Right: Visual Elements -->
      <div class="relative">
        <div class="relative bg-white/10 backdrop-blur-sm rounded-3xl p-8 border border-white/20">
          <div class="text-center mb-6">
            <img 
              src="https://images.unsplash.com/photo-1466611653911-95081537e5b7?w=600&q=80" 
              alt="Lắp đặt điện mặt trời"
              class="w-full h-48 object-cover rounded-2xl mb-4"
            />
            <h4 class="text-xl font-semibold text-white mb-2">
              Trải nghiệm thực tế ảo
            </h4>
            <p class="text-gray-300 text-sm">
              Khám phá showroom 3D với công nghệ VR/AR tiên tiến
            </p>
          </div>
          
          <div class="space-y-4">
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-400 rounded-full"></div>
              <span class="text-gray-300">Thiết kế 3D theo yêu cầu</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-blue-400 rounded-full"></div>
              <span class="text-gray-300">Tư vấn solar chuyên nghiệp</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-purple-400 rounded-full"></div>
              <span class="text-gray-300">Lắp đặt và bảo hành toàn diện</span>
            </div>
          </div>
        </div>
        
        <!-- Floating Stats -->
        <div class="absolute -top-8 -right-8 bg-gradient-to-r from-cyan-600 to-blue-600 rounded-2xl p-4 shadow-2xl">
          <div class="text-center">
            <div class="text-2xl font-bold text-white">98%</div>
            <div class="text-cyan-200 text-sm">Hài lòng</div>
          </div>
        </div>
        
        <div class="absolute -bottom-8 -left-8 bg-gradient-to-r from-purple-600 to-pink-600 rounded-2xl p-4 shadow-2xl">
          <div class="text-center">
            <div class="text-2xl font-bold text-white">500+</div>
            <div class="text-purple-200 text-sm">Khách hàng</div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Action Buttons -->
    <div class="mt-16 text-center">
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
        <button class="group relative bg-gradient-to-r from-cyan-600 to-blue-600 text-white px-12 py-6 rounded-2xl font-bold text-lg shadow-2xl hover:shadow-3xl transition-all duration-300 transform hover:scale-105 overflow-hidden">
          <span class="relative z-10 flex items-center">
            <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
            Tư vấn miễn phí ngay
          </span>
          <div class="absolute inset-0 bg-gradient-to-r from-cyan-700 to-blue-700 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </button>
        
        <button class="group bg-white/10 backdrop-blur-sm text-white px-12 py-6 rounded-2xl font-bold text-lg shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:scale-105 border border-white/20 hover:bg-white/20">
          <span class="flex items-center">
            <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
            </svg>
            Xem showroom 3D
          </span>
        </button>
      </div>
      
      <div class="mt-8 text-center">
        <p class="text-gray-300 text-sm">
          🚀 Miễn phí thiết kế 3D • 📞 Tư vấn 24/7 • 🛠️ Bảo hành 5 năm
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .shadow-3xl {
    box-shadow: 0 35px 60px -12px rgba(0, 0, 0, 0.25);
  }
  
  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }
  
  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
</style> 