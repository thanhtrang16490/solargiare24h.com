---
import Layout from '../../layouts/Layout.astro';
import { COMPANY_INFO } from '../../constants';
---
<Layout title="Chính sách đổi trả - SOLAR24H" description="SOLAR24H cam kết đảm bảo quyền lợi khách hàng với chính sách đổi trả linh hoạt, minh bạch. Đổi trả trong 7 ngày, miễn phí nếu lỗi sản xuất.">
  <div class="min-h-screen bg-gray-50">
    <!-- Header Section -->
    <div class="bg-gradient-to-r from-orange-500 to-red-500 text-white py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 text-sm font-medium mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
            </svg>
            Quyền lợi khách hàng
          </div>
          <h1 class="text-4xl md:text-5xl font-bold mb-4">
            Chính sách đổi trả
          </h1>
          <p class="text-xl opacity-90 max-w-2xl mx-auto">
            {COMPANY_INFO.shortName} cam kết bảo vệ quyền lợi khách hàng với chính sách đổi trả linh hoạt và minh bạch
          </p>
        </div>
      </div>
    </div>

    <div class="container mx-auto px-4 py-12">
      <div class="max-w-4xl mx-auto">
        
        <!-- Quick Overview -->
        <div class="grid md:grid-cols-3 gap-6 mb-12">
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-200 text-center">
            <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">7 ngày đổi trả</h3>
            <p class="text-gray-600">Thời gian đổi trả linh hoạt kể từ ngày nhận hàng</p>
          </div>
          
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-200 text-center">
            <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Miễn phí đổi trả</h3>
            <p class="text-gray-600">Không tính phí nếu sản phẩm có lỗi từ nhà sản xuất</p>
          </div>
          
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-200 text-center">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Quy trình đơn giản</h3>
            <p class="text-gray-600">Chỉ cần gọi điện hoặc đến showroom để đổi trả</p>
          </div>
        </div>

        <!-- Return Conditions -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 mb-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">📋 Điều kiện đổi trả</h2>
          
          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <h3 class="font-semibold text-green-800 mb-4 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Được chấp nhận đổi trả
              </h3>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <span class="w-2 h-2 bg-green-500 rounded-full mt-2 flex-shrink-0"></span>
                  <span class="text-gray-700">Sản phẩm còn nguyên vẹn, không bị trầy xước, hư hỏng</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-2 h-2 bg-green-500 rounded-full mt-2 flex-shrink-0"></span>
                  <span class="text-gray-700">Còn đầy đủ phụ kiện, bao bì, hướng dẫn sử dụng</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-2 h-2 bg-green-500 rounded-full mt-2 flex-shrink-0"></span>
                  <span class="text-gray-700">Có hóa đơn mua hàng và phiếu bảo hành</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-2 h-2 bg-green-500 rounded-full mt-2 flex-shrink-0"></span>
                  <span class="text-gray-700">Trong thời hạn 7 ngày kể từ ngày nhận hàng</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-2 h-2 bg-green-500 rounded-full mt-2 flex-shrink-0"></span>
                  <span class="text-gray-700">Sản phẩm chưa qua sử dụng hoặc có dấu hiệu sử dụng</span>
                </li>
              </ul>
            </div>
            
            <div>
              <h3 class="font-semibold text-red-800 mb-4 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Không được chấp nhận
              </h3>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <span class="w-2 h-2 bg-red-500 rounded-full mt-2 flex-shrink-0"></span>
                  <span class="text-gray-700">Sản phẩm đã qua sử dụng, có dấu hiệu hao mòn</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-2 h-2 bg-red-500 rounded-full mt-2 flex-shrink-0"></span>
                  <span class="text-gray-700">Thiếu phụ kiện, bao bì hoặc hướng dẫn</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-2 h-2 bg-red-500 rounded-full mt-2 flex-shrink-0"></span>
                  <span class="text-gray-700">Quá thời hạn 7 ngày đổi trả</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-2 h-2 bg-red-500 rounded-full mt-2 flex-shrink-0"></span>
                  <span class="text-gray-700">Hư hỏng do lỗi sử dụng của khách hàng</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-2 h-2 bg-red-500 rounded-full mt-2 flex-shrink-0"></span>
                  <span class="text-gray-700">Sản phẩm đặt hàng theo yêu cầu riêng</span>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Return Process -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 mb-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">🔄 Quy trình đổi trả</h2>
          
          <div class="grid md:grid-cols-4 gap-6">
            <div class="text-center">
              <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-2xl font-bold text-blue-600">1</span>
              </div>
              <h4 class="font-semibold mb-2">Liên hệ</h4>
              <p class="text-sm text-gray-600">Gọi hotline {COMPANY_INFO.hotline} hoặc đến showroom để thông báo đổi trả</p>
            </div>
            
            <div class="text-center">
              <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-2xl font-bold text-green-600">2</span>
              </div>
              <h4 class="font-semibold mb-2">Kiểm tra</h4>
              <p class="text-sm text-gray-600">Nhân viên kiểm tra điều kiện sản phẩm và xác nhận đổi trả</p>
            </div>
            
            <div class="text-center">
              <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-2xl font-bold text-orange-600">3</span>
              </div>
              <h4 class="font-semibold mb-2">Xử lý</h4>
              <p class="text-sm text-gray-600">Tiến hành đổi sản phẩm mới hoặc hoàn tiền theo yêu cầu</p>
            </div>
            
            <div class="text-center">
              <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-2xl font-bold text-purple-600">4</span>
              </div>
              <h4 class="font-semibold mb-2">Hoàn tất</h4>
              <p class="text-sm text-gray-600">Khách hàng nhận sản phẩm mới hoặc tiền hoàn</p>
            </div>
          </div>
        </div>

        <!-- Return Fees -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 mb-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">💰 Chi phí đổi trả</h2>
          
          <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-green-50 border border-green-200 rounded-lg p-6">
              <h3 class="font-semibold text-green-800 mb-3 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                </svg>
                Miễn phí đổi trả
              </h3>
              <ul class="space-y-2 text-green-700">
                <li>• Sản phẩm có lỗi từ nhà sản xuất</li>
                <li>• Giao sai sản phẩm</li>
                <li>• Sản phẩm bị hư hỏng trong vận chuyển</li>
                <li>• Không đúng mô tả trên website</li>
              </ul>
            </div>
            
            <div class="bg-orange-50 border border-orange-200 rounded-lg p-6">
              <h3 class="font-semibold text-orange-800 mb-3 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Có phí đổi trả
              </h3>
              <ul class="space-y-2 text-orange-700">
                <li>• Đổi do không vừa ý (phí vận chuyển 2 chiều)</li>
                <li>• Đổi sang sản phẩm khác (phí chênh lệch)</li>
                <li>• Hoàn tiền (phí xử lý 2% giá trị đơn hàng)</li>
                <li>• Đổi trả tại nhà (phí dịch vụ 50,000đ)</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Contact Information -->
        <div class="bg-gradient-to-r from-blue-600 to-purple-600 rounded-xl p-8 text-white">
          <div class="text-center mb-6">
            <h2 class="text-2xl font-bold mb-2">Cần hỗ trợ đổi trả?</h2>
            <p class="opacity-90">Liên hệ ngay với đội ngũ {COMPANY_INFO.shortName} để được hỗ trợ nhanh chóng</p>
          </div>
          
          <div class="grid md:grid-cols-3 gap-6 text-center">
            <div>
              <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-3">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
              </div>
              <h3 class="font-semibold mb-1">Hotline</h3>
              <p class="text-sm opacity-90">{COMPANY_INFO.hotline}</p>
              <p class="text-xs opacity-75">{COMPANY_INFO.supportHours}</p>
            </div>
            
            <div>
              <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-3">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <h3 class="font-semibold mb-1">Email</h3>
              <p class="text-sm opacity-90">{COMPANY_INFO.email}</p>
              <p class="text-xs opacity-75">Phản hồi trong 24h</p>
            </div>
            
            <div>
              <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-3">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <h3 class="font-semibold mb-1">Showroom</h3>
              <p class="text-sm opacity-90">3 cửa hàng</p>
              <p class="text-xs opacity-75">HN & HCM</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</Layout> 