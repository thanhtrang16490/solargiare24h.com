---
import Layout from '../layouts/Layout.astro';
import VideoListIsland from '../components/VideoListIsland.astro';

const title = 'Video Sản Phẩm - G3 Solar';
const description = 'Khám phá các sản phẩm solar qua video chi tiết. Xem trực tiếp cách sử dụng và đánh giá sản phẩm từ G3 Solar.';
---

<Layout title={title} description={description}>
  <div class="bg-black h-screen overflow-hidden">
    <!-- Desktop Notice -->
    <div class="hidden md:flex items-center justify-center h-full">
      <div class="text-center text-white">
        <div class="mb-4">
          <svg class="w-16 h-16 mx-auto text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
          </svg>
        </div>
        <h2 class="text-xl font-semibold mb-2">Chức năng video dành cho di động</h2>
        <p class="text-gray-400">Vui lòng sử dụng thiết bị di động để xem video sản phẩm</p>
      </div>
    </div>

    <!-- Mobile Video List -->
    <div class="md:hidden h-full">
      <VideoListIsland />
    </div>
  </div>
</Layout> 