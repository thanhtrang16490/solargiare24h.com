---
import Layout from '../../layouts/Layout.astro';
import { MOCK_BRANDS } from '../../data/mock-products';

const brands = MOCK_BRANDS as any[];

const title = 'Thương hiệu | G3 - Solar';
const description = 'Khám phá các thương hiệu thiết bị năng lượng mặt trời tại G3.vn. Thiết bị năng lượng mặt trời, bảo hành 12 tháng, giao hàng toàn quốc.';
---

<Layout title={title} description={description}>
  <!-- Mobile View -->
  <div class="md:hidden -mb-20">
    <div class="px-4 py-4">
      {brands.length > 0 ? (
        <div class="grid grid-cols-2 gap-4">
          {brands.map((brand: any) => (
            <a href={`/brands/${brand.slug}`} class="block">
              <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
                <div class="aspect-square w-full overflow-hidden rounded-lg bg-gray-100">
                  {brand.image_square_url || brand.image_url ? (
                    <img
                      src={brand.image_square_url || brand.image_url}
                      alt={brand.title}
                      class="h-full w-full object-contain"
                    />
                  ) : (
                    <div class="flex h-full items-center justify-center">
                      <span class="text-2xl font-bold text-gray-400">
                        {brand.title.charAt(0)}
                      </span>
                    </div>
                  )}
                </div>
                <div class="mt-4">
                  <h3 class="text-lg font-semibold text-gray-900">
                    {brand.title}
                  </h3>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="rounded-lg border border-gray-200 bg-white p-4 text-center shadow-sm">
          <p class="text-base text-gray-600">Không tìm thấy thương hiệu nào.</p>
        </div>
      )}
    </div>
  </div>

  <!-- Desktop View -->
  <div class="hidden md:block container mx-10 px-2 py-4">
    {brands.length > 0 ? (
      <div class="grid grid-cols-3 gap-4 lg:grid-cols-5">
        {brands.map((brand: any) => (
          <a href={`/brands/${brand.slug}`} class="block">
            <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm hover:shadow-md transition-shadow">
              <div class="aspect-square w-full overflow-hidden rounded-lg bg-gray-100">
                {brand.image_square_url || brand.image_url ? (
                  <img
                    src={brand.image_square_url || brand.image_url}
                    alt={brand.title}
                    class="h-full w-full object-contain"
                  />
                ) : (
                  <div class="flex h-full items-center justify-center">
                    <span class="text-2xl font-bold text-gray-400">
                      {brand.title.charAt(0)}
                    </span>
                  </div>
                )}
              </div>
              <div class="mt-4">
                <h3 class="text-lg font-semibold text-gray-900">
                  {brand.title}
                </h3>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="rounded-lg border border-gray-200 bg-white p-4 text-center shadow-sm">
        <p class="text-base text-gray-600">Không tìm thấy thương hiệu nào.</p>
      </div>
    )}
  </div>
</Layout>

<style>
  .aspect-square {
    aspect-ratio: 1 / 1;
  }
</style> 