---
import Layout from '../layouts/Layout.astro';
import MobileFeedIsland from '../components/MobileFeedIsland.astro';

const title = 'Feed - G3 Solar';
const description = 'Theo dõi những tin tức, khuyến mãi và sản phẩm mới nhất từ G3 Solar. Cập nhật liên tục các thông tin về hệ thống điện mặt trời.';
---

<Layout title={title} description={description}>
  <div class="min-h-screen bg-gray-200">
    <!-- Main Content - Full Width -->
    <MobileFeedIsland />
  </div>
</Layout>