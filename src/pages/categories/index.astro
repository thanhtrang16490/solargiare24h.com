---
import Layout from "../../layouts/Layout.astro";
import { MOCK_CATEGORIES, MOCK_BRANDS } from "../../data/mock-products";
import MobileCategoryList from "../../components/mobile/MobileCategoryList";

const categories = MOCK_CATEGORIES as any[];
const brands = MOCK_BRANDS as any[];

const title = "Danh mục & Thương hiệu | G3 - Solar";
const description =
  "Khám phá các danh mục sản phẩm và thương hiệu điện mặt trời tại solargiare24h.com. Thiết bị năng lượng mặt trời, bảo hành 12 tháng, giao hàng toàn quốc.";
---

<Layout title={title} description={description}>
  <!-- Mobile View -->
  <div class="md:hidden -mb-20">
    <MobileCategoryList categories={categories} brands={brands} client:load />
  </div>

  <!-- Desktop View -->
  <div class="hidden md:block container mx-10 px-2 py-4 space-y-8">
    <!-- Categories Section -->
    <div>
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Danh mục sản phẩm</h2>
      {
        categories.length > 0 ? (
          <div class="grid grid-cols-3 gap-4 lg:grid-cols-5">
            {categories.map((category: any) => (
              <a href={`/categories/${category.slug}`} class="block">
                <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm hover:shadow-md transition-shadow">
                  <div class="aspect-square w-full overflow-hidden rounded-lg bg-gray-100">
                    {category.image_square_url || category.image_url ? (
                      <img
                        src={category.image_square_url || category.image_url}
                        alt={category.title}
                        class="h-full w-full object-contain"
                      />
                    ) : (
                      <div class="flex h-full items-center justify-center">
                        <span class="text-2xl font-bold text-gray-400">
                          {category.title.charAt(0)}
                        </span>
                      </div>
                    )}
                  </div>
                  <div class="mt-4">
                    <h3 class="text-lg font-semibold text-gray-900">
                      {category.title}
                    </h3>
                    {category.description && (
                      <p class="mt-1 text-sm text-gray-600">
                        {category.description}
                      </p>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="rounded-lg border border-gray-200 bg-white p-4 text-center shadow-sm">
            <p class="text-base text-gray-600">Không tìm thấy danh mục nào.</p>
          </div>
        )
      }
    </div>

    <!-- Brands Section -->
    <div>
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Thương hiệu</h2>
      {
        brands.length > 0 ? (
          <div class="grid grid-cols-3 gap-4 lg:grid-cols-5">
            {brands.map((brand: any) => (
              <a href={`/brands/${brand.slug}`} class="block">
                <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm hover:shadow-md transition-shadow">
                  <div class="aspect-square w-full overflow-hidden rounded-lg bg-gray-100">
                    {brand.image_square_url || brand.image_url ? (
                      <img
                        src={brand.image_square_url || brand.image_url}
                        alt={brand.title}
                        class="h-full w-full object-contain"
                      />
                    ) : (
                      <div class="flex h-full items-center justify-center">
                        <span class="text-2xl font-bold text-gray-400">
                          {brand.title.charAt(0)}
                        </span>
                      </div>
                    )}
                  </div>
                  <div class="mt-4">
                    <h3 class="text-lg font-semibold text-gray-900">
                      {brand.title}
                    </h3>
                    {brand.description && (
                      <p class="mt-1 text-sm text-gray-600">
                        {brand.description}
                      </p>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="rounded-lg border border-gray-200 bg-white p-4 text-center shadow-sm">
            <p class="text-base text-gray-600">
              Không tìm thấy thương hiệu nào.
            </p>
          </div>
        )
      }
    </div>
  </div>
</Layout>

<style>
  .aspect-square {
    aspect-ratio: 1 / 1;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.3s ease-out;
  }
</style>
