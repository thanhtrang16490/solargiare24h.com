---
import Layout from '../layouts/Layout.astro';
import VoucherListIsland from '../components/VoucherListIsland.astro';

const title = 'Voucher Khuyến Mãi - G3 Solar';
const description = 'Tổng hợp các voucher khuyến mãi, mã giảm giá và ưu đãi đặc biệt từ G3 Solar. Tiết kiệm chi phí khi mua sắm thiết bị hệ thống điện mặt trời.';
---

<Layout title={title} description={description}>
  <div class="min-h-screen bg-gray-100">
    <!-- Main Content - Full Width -->
    <VoucherListIsland />
  </div>
</Layout> 