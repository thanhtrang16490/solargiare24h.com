---
import Layout from '../layouts/Layout.astro';
import ShoppingGuide3D from '../components/react/ShoppingGuide3D';
import InteractiveStepper from '../components/react/InteractiveStepper';
import { COMPANY_INFO, SOCIAL_LINKS } from '../constants';



// Format phone number for display
function formatPhoneNumber(phoneNumber: string): string {
  const cleaned = phoneNumber.replace(/\D/g, '');
  const match = cleaned.match(/^(\d{4})(\d{3})(\d{3})$/);
  if (match) {
    return `${match[1]}.${match[2]}.${match[3]}`;
  }
  return phoneNumber;
}

const formattedPhone = formatPhoneNumber(COMPANY_INFO.hotline);
---

<Layout title="Hướng dẫn mua hàng - SOLAR24H | Nhiều kênh mua hàng linh hoạt" description="Hướng dẫn mua hàng tại SOLAR24H với nhiều kênh: Hotline, Zalo, Facebook, Website, Showroom. Quy trình đơn giản, thanh toán linh hoạt, giao hàng toàn quốc.">
  <div class="bg-white">
    <!-- Hero Section với Three.js -->
    <section class="relative h-screen flex items-center justify-center bg-gradient-to-br from-blue-50 via-white to-pink-50 overflow-hidden">
      <!-- Background Image Overlay -->
      <div class="absolute inset-0 z-0">
        <img 
          src="https://images.unsplash.com/photo-1497366216548-37526070297c?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" 
          alt="Hệ thống điện mặt trời SOLAR24H"
          class="w-full h-full object-cover opacity-10"
        />
      </div>
      
      <!-- Three.js Background -->
      <div class="absolute inset-0 z-10">
        <ShoppingGuide3D client:load />
      </div>
      
      <!-- Hero Content -->
      <div class="relative z-20 text-center px-4 max-w-4xl mx-auto">
        <h1 class="text-6xl md:text-8xl font-bold text-gray-900 mb-6 leading-tight">
          Hướng dẫn mua hàng 
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-pink-500">
            tại SOLAR24H
          </span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-600 mb-8 font-light">
          {COMPANY_INFO.name} cung cấp nhiều kênh mua hàng linh hoạt – từ showroom đến online
        </p>
        <button 
          onclick="document.getElementById('channels-section').scrollIntoView({ behavior: 'smooth' })"
          class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-red-500 to-pink-500 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transform hover:scale-105 transition-all duration-300 text-lg"
        >
          Bắt đầu mua ngay
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </button>
      </div>
    </section>

    <!-- Các kênh mua hàng -->
    <section id="channels-section" class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Các kênh mua hàng</h2>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            Chọn kênh mua hàng phù hợp nhất với bạn
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Hotline -->
          <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2">
            <div class="w-20 h-20 bg-gradient-to-r from-green-400 to-blue-500 rounded-full flex items-center justify-center mb-6 mx-auto">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">📞 Hotline</h3>
            <p class="text-gray-600 text-center mb-6">
              Gọi ngay {formattedPhone} để được tư vấn viên hỗ trợ trực tiếp
            </p>
            <img 
              src="https://images.unsplash.com/photo-1553484771-371a605b060b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
              alt="Tư vấn viên SOLAR24H hỗ trợ khách hàng qua hotline" 
              class="w-full h-48 object-cover rounded-lg mb-6 hover:scale-105 transition-transform duration-300"
            />
            <div class="text-center">
              <a 
                href={`tel:${COMPANY_INFO.hotline}`} 
                class="inline-flex items-center px-6 py-3 bg-green-500 text-white rounded-lg hover:bg-green-600 transition-colors"
              >
                Gọi ngay
              </a>
            </div>
          </div>

          <!-- Showroom -->
          <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2">
            <div class="w-20 h-20 bg-gradient-to-r from-purple-400 to-pink-500 rounded-full flex items-center justify-center mb-6 mx-auto">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">🏢 Tại Showroom</h3>
            <p class="text-gray-600 text-center mb-6">
              Đến trực tiếp showroom để trải nghiệm sản phẩm thực tế
            </p>
            <img 
              src="https://images.unsplash.com/photo-1586023492125-27b2c045efd7?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
              alt="Showroom SOLAR24H với điện mặt trời hiện đại" 
              class="w-full h-48 object-cover rounded-lg mb-6 hover:scale-105 transition-transform duration-300"
            />
            <div class="text-center space-y-2">
              <div class="text-sm text-gray-500">Liên hệ hotline để biết địa chỉ showroom</div>
              <div class="mt-4">
                <a 
                  href={`tel:${COMPANY_INFO.hotline}`}
                  class="inline-flex items-center px-6 py-3 bg-purple-500 text-white rounded-lg hover:bg-purple-600 transition-colors"
                >
                  Gọi ngay
                </a>
              </div>
            </div>
          </div>

          <!-- Zalo -->
          <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2">
            <div class="w-20 h-20 bg-gradient-to-r from-blue-400 to-indigo-500 rounded-full flex items-center justify-center mb-6 mx-auto">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">💬 Zalo OA</h3>
            <p class="text-gray-600 text-center mb-6">
              Mua trực tiếp trên Zalo Official Account với hỗ trợ tức thời
            </p>
            <img 
              src="https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
              alt="Chat Zalo với SOLAR24H - tư vấn nhanh chóng qua tin nhắn" 
              class="w-full h-48 object-cover rounded-lg mb-6 hover:scale-105 transition-transform duration-300"
            />
            <div class="text-center">
              <a 
                href={COMPANY_INFO.zalo} 
                target="_blank"
                class="inline-flex items-center px-6 py-3 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition-colors"
              >
                Chat Zalo
              </a>
            </div>
          </div>

          <!-- Facebook -->
          <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2">
            <div class="w-20 h-20 bg-gradient-to-r from-blue-600 to-purple-600 rounded-full flex items-center justify-center mb-6 mx-auto">
              <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">💻 Facebook Page</h3>
            <p class="text-gray-600 text-center mb-6">
              Đặt hàng qua fanpage Messenger với nhiều ưu đãi hấp dẫn
            </p>
            <img 
              src="https://images.unsplash.com/photo-1611262588024-d12430b98920?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
              alt="Fanpage Facebook SOLAR24H - kết nối và nhận tin tức mới nhất" 
              class="w-full h-48 object-cover rounded-lg mb-6 hover:scale-105 transition-transform duration-300"
            />
            <div class="text-center">
              <a 
                href={SOCIAL_LINKS.find(link => link.name === 'Facebook')?.href} 
                target="_blank"
                class="inline-flex items-center px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
              >
                Trang Facebook
              </a>
            </div>
          </div>

          <!-- Website -->
          <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 lg:col-span-2">
            <div class="w-20 h-20 bg-gradient-to-r from-red-400 to-pink-500 rounded-full flex items-center justify-center mb-6 mx-auto">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4m0 0L7 13m0 0l-2.5 5L17 18"></path>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">🛒 Trên Website</h3>
            <p class="text-gray-600 text-center mb-6">
              Chọn sản phẩm → Thêm giỏ hàng → Gửi đơn hàng trực tiếp trên website
            </p>
            <img 
              src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
              alt="Mua sắm trực tuyến trên website SOLAR24H - dễ dàng và tiện lợi" 
              class="w-full h-48 object-cover rounded-lg mb-6 hover:scale-105 transition-transform duration-300"
            />
            <div class="text-center">
              <a 
                href="/san-pham" 
                class="inline-flex items-center px-6 py-3 bg-red-500 text-white rounded-lg hover:bg-red-600 transition-colors"
              >
                Xem sản phẩm
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Quy trình đặt hàng -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Quy trình đặt hàng</h2>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            4 bước đơn giản để có được sản phẩm ưng ý
          </p>
        </div>
        
        <InteractiveStepper client:load />
      </div>
    </section>

    <!-- Hình thức thanh toán -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Hình thức thanh toán</h2>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            Nhiều phương thức thanh toán linh hoạt
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- COD -->
          <div class="bg-white rounded-xl shadow-lg p-8 text-center hover:shadow-xl transition-all duration-300">
            <div class="w-24 h-24 bg-green-100 rounded-full flex items-center justify-center mb-6 mx-auto overflow-hidden">
              <img 
                src="https://images.unsplash.com/photo-1563013544-824ae1b704d3?ixlib=rb-4.0.3&auto=format&fit=crop&w=200&q=80" 
                alt="Thanh toán khi nhận hàng COD"
                class="w-full h-full object-cover"
              />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">COD</h3>
            <p class="text-gray-600">Thanh toán khi nhận hàng (COD) - An toàn và tiện lợi</p>
          </div>

          <!-- Chuyển khoản -->
          <div class="bg-white rounded-xl shadow-lg p-8 text-center hover:shadow-xl transition-all duration-300">
            <div class="w-24 h-24 bg-blue-100 rounded-full flex items-center justify-center mb-6 mx-auto overflow-hidden">
              <img 
                src="https://images.unsplash.com/photo-1563013544-824ae1b704d3?ixlib=rb-4.0.3&auto=format&fit=crop&w=200&q=80" 
                alt="Chuyển khoản ngân hàng online"
                class="w-full h-full object-cover"
              />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Chuyển khoản</h3>
            <p class="text-gray-600">Chuyển khoản ngân hàng trực tiếp với thông tin rõ ràng</p>
          </div>

          <!-- Tại showroom -->
          <div class="bg-white rounded-xl shadow-lg p-8 text-center hover:shadow-xl transition-all duration-300">
            <div class="w-24 h-24 bg-purple-100 rounded-full flex items-center justify-center mb-6 mx-auto overflow-hidden">
              <img 
                src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?ixlib=rb-4.0.3&auto=format&fit=crop&w=200&q=80" 
                alt="Thanh toán tại showroom SOLAR24H"
                class="w-full h-full object-cover"
              />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Tại showroom</h3>
            <p class="text-gray-600">Thanh toán bằng thẻ hoặc tiền mặt trực tiếp tại showroom</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Giao hàng và lắp đặt -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-gray-900 mb-4">Giao hàng và lắp đặt</h2>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            Dịch vụ giao hàng và lắp đặt chuyên nghiệp
          </p>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <img 
              src="https://images.unsplash.com/photo-1566576912321-d58ddd7a6088?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
              alt="Dịch vụ giao hàng chuyên nghiệp của SOLAR24H tận nơi" 
              class="w-full h-80 object-cover rounded-xl shadow-lg hover:scale-105 transition-transform duration-300"
            />
          </div>
          
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">Miễn phí vận chuyển</h3>
                <p class="text-gray-600">Miễn phí giao hàng nội thành HN & HCM với đơn hàng trên 2 triệu đồng</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">Giao hàng toàn quốc</h3>
                <p class="text-gray-600">Giao hàng toàn quốc trong 3-5 ngày làm việc</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">Lắp đặt chuyên nghiệp</h3>
                <p class="text-gray-600">Đội ngũ kỹ thuật viên chuyên nghiệp miễn phí lắp đặt</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA cuối trang -->
    <section class="py-20 bg-gradient-to-r from-red-500 to-pink-500 text-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-4xl font-bold mb-4">Bạn cần hỗ trợ ngay?</h2>
        <p class="text-xl mb-8 opacity-90">
          Đội ngũ tư vấn viên SOLAR24H luôn sẵn sàng hỗ trợ bạn ({COMPANY_INFO.workingHours})
        </p>
        
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a 
            href={`tel:${COMPANY_INFO.hotline}`} 
            class="inline-flex items-center px-8 py-4 bg-white text-red-500 font-semibold rounded-xl shadow-lg hover:shadow-xl transform hover:scale-105 transition-all duration-300"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Hotline: {formattedPhone}
          </a>
          
          <a 
            href={COMPANY_INFO.zalo} 
            target="_blank"
            class="inline-flex items-center px-8 py-4 bg-blue-500 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transform hover:scale-105 transition-all duration-300 hover:bg-blue-600"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
            Chat Zalo
          </a>
        </div>
        
        <div class="mt-8">
          <img 
